# Château de Lésigny — optional feature configuration
# Copy to `.env` (or set in your host's build env) and fill in to ACTIVATE a
# feature. Every value is OPTIONAL: leave it blank and the feature stays hidden
# (no empty "coming soon" shell). Enabling a third-party service automatically
# updates the privacy policy (src/pages/[locale]/confidentialite.astro reads
# src/config/features.ts), so the published policy always matches the live site.
#
# PUBLIC_ vars are exposed to the browser (required for client-side features).

# --- Preview / demo mode ---
# Set to 1 (or run `npm run dev:demo` / `npm run build:demo`) to populate EVERY gated
# feature with realistic demo data so you can SEE them — reviews + stars, before/after
# slider, 360 tour, gift vouchers, newsletter, and a filled Mentions légales. This is
# preview-only: a production/go-live build with PUBLIC_DEMO set is BLOCKED by the
# check-todos gate, so demo data can never ship live.
PUBLIC_DEMO=

# --- Enquiry form delivery (pick ONE; else the form opens the visitor's mail app) ---
# Web3Forms access key (https://web3forms.com — free). Enable auto-reply in their dashboard.
PUBLIC_WEB3FORMS_KEY=
# ...or a custom endpoint (e.g. a Cloudflare Pages Function) that accepts a JSON POST.
PUBLIC_INQUIRY_ENDPOINT=

# --- Cookieless analytics (no cookie banner required) ---
# Cloudflare Web Analytics beacon token (https://dash.cloudflare.com → Web Analytics).
PUBLIC_CF_BEACON=
# ...or a Plausible data-domain (https://plausible.io).
PUBLIC_PLAUSIBLE_DOMAIN=

# --- Newsletter (Brevo, EU-hosted) ---
# The action URL of your Brevo hosted signup form (…sibforms.com/serve/…).
PUBLIC_NEWSLETTER_URL=

# --- Gift vouchers (Stripe Payment Links — hosted, PCI-free) ---
PUBLIC_VOUCHER_STAY_URL=
PUBLIC_VOUCHER_SHOP_URL=

# --- 360° virtual tour (Kuula / Panoee embed URL; loads only after consent) ---
PUBLIC_TOUR360_URL=

# --- Video / drone hero (path to an mp4 in public/, e.g. /media/hero.mp4) ---
PUBLIC_HERO_VIDEO=

# NOTE: two features are set in code, not env, because they carry structured
# content/assets rather than a single URL — edit src/config/features.ts:
#   • reviews  → paste real Google/Mariages.net ratings + quotes (never fabricated;
#                stars + AggregateRating schema appear only when real data is present)
#   • beforeAfter → owner rights-cleared before/after image pairs for the restoration
#                   slider on the history page (HGTV broadcast stills are copyrighted)
