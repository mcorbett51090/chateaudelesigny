---
/**
 * ReviewsFrame — visible star rating + review quotes, shown ONLY when real
 * reviews are entered in `features.reviews` (never fabricated). When empty it
 * renders nothing, so the page keeps its existing honest "reviews on our
 * platforms" fallback instead of an empty shell. The matching AggregateRating
 * JSON-LD is emitted from schema.ts under the same `hasReviews` gate, so the
 * structured data never appears without the visible content.
 */
import { type Locale, useT } from '../i18n/ui';
import { features, hasReviews } from '../config/features';

const locale = (Astro.props.locale ?? 'fr') as Locale;
const t = useT(locale);
const r = features.reviews;
const full = Math.max(0, Math.min(5, Math.round(r.ratingValue)));
const stars = '★★★★★'.slice(0, full) + '☆☆☆☆☆'.slice(0, 5 - full);
---
{hasReviews && (
  <section class="rv section" aria-labelledby="rv-h2">
    <div class="wrap">
      <p class="eyebrow" id="rv-h2">{t('reviews.title')}</p>
      <p class="rv__score">
        <span class="rv__stars" aria-hidden="true">{stars}</span>
        <span class="rv__num">{r.ratingValue.toFixed(1)}/5</span>
        <span class="rv__count slate">· {r.reviewCount} {t('reviews.based')}</span>
        {r.url && (
          <a class="rv__src" href={r.url} target="_blank" rel="noopener noreferrer">↗</a>
        )}
      </p>
      {r.items.length > 0 && (
        <ul class="rv__list" role="list">
          {r.items.map((it) => (
            <li class="rv__item">
              <p class="rv__text">“{it.text}”</p>
              <p class="rv__author">{it.author} <span class="slate">· {it.source}</span></p>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
)}

<style>
  .rv__score { display: flex; align-items: baseline; gap: var(--space-2xs); margin-top: var(--space-s); }
  .rv__stars { color: var(--laiton-deep); font-size: var(--step-2); letter-spacing: 0.08em; }
  .rv__num { font-family: var(--font-display); font-size: var(--step-2); color: var(--text); }
  .rv__count { font-size: var(--step-0); }
  .rv__src { margin-left: var(--space-2xs); color: var(--laiton-deep); text-decoration: none; }
  .rv__list {
    list-style: none; padding: 0; margin: var(--space-l) 0 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-l);
  }
  .rv__item { border-top: var(--hairline) solid var(--rule); padding-top: var(--space-m); }
  .rv__text { font-family: var(--font-display); font-style: italic; font-size: var(--step-1); color: var(--text); line-height: 1.5; }
  .rv__author { font-size: var(--step--1); color: var(--text-muted); margin-top: var(--space-s); }
  @media (max-width: 820px) { .rv__list { grid-template-columns: 1fr; gap: var(--space-m); } }
</style>
