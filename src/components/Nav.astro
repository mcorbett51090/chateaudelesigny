---
import { type Locale, useT, localeBase, withBase } from '../i18n/ui';
import LangSwitcher from './LangSwitcher.astro';
const locale = (Astro.props.locale ?? 'fr') as Locale;
const t = useT(locale);
const base = localeBase(locale);
const links = [
  { href: `${base}/le-domaine/`, label: t('nav.domaine') },
  { href: `${base}/mariages/`, label: t('nav.mariages') },
  { href: `${base}/tournages/`, label: t('nav.tournages') },
  { href: `${base}/photographes/`, label: t('nav.photographes') },
  { href: `${base}/partenaires/`, label: t('nav.partenaires') },
  { href: `${base}/histoire/`, label: t('nav.histoire') },
  { href: `${base}/boutique/`, label: t('nav.boutique') },
  { href: `${base}/social/`, label: t('nav.social') },
];
const here = Astro.url.pathname;
---
<header class="nav" data-nav>
  <div class="nav__inner wrap-wide">
    <a class="nav__brand" href={`${base}/`} aria-label="Château de Lésigny">
      <img class="nav__crest" src={withBase('/crest-lesigny.svg')} alt="" width="40" height="44" />
      <span class="nav__word">Château de Lésigny</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} aria-current={here.startsWith(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
    </nav>

    <div class="nav__actions">
      <LangSwitcher />
      <a class="btn btn--primary nav__cta" href={`${base}/contact/`}>{t('cta.inquiry')}</a>
    </div>

    <button class="nav__burger" aria-label={t('nav.menu')} aria-expanded="false" aria-controls="nav-drawer" data-burger>
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__drawer" id="nav-drawer" data-drawer hidden>
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
    <a class="btn btn--primary" href={`${base}/contact/`}>{t('cta.inquiry')}</a>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--pierre) 86%, transparent);
    backdrop-filter: blur(12px) saturate(1.1);
    border-bottom: var(--hairline) solid var(--rule);
    /* The nav bar keeps its light translucent background on every page, so its
       text must stay dark even when the page sets `.is-dark` on <html> (e.g. the
       Filming page) — otherwise all nav text inherits ivory and vanishes. */
    color: var(--encre);
    --text-muted: var(--encre-soft);
    --rule: color-mix(in srgb, var(--laiton) 55%, transparent);
  }
  .nav__inner {
    display: flex; align-items: center; gap: var(--space-m);
    min-height: 4.5rem; padding-block: var(--space-2xs);
  }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__crest { height: 2.7rem; width: auto; display: block; }
  .nav__word {
    font-family: var(--font-display); font-size: var(--step-1);
    font-weight: 440; letter-spacing: -0.01em;
  }
  .nav__links { display: flex; gap: var(--space-s); margin-inline-start: auto; min-width: 0; }
  .nav__links a {
    font-family: var(--font-ui); font-size: var(--step--1);
    text-transform: uppercase; letter-spacing: 0.1em;
    text-decoration: none; padding-block: 0.3em;
    border-bottom: 2px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-soft);
  }
  .nav__links a:hover, .nav__links a[aria-current='page'] { border-color: var(--encre); }
  .nav__actions { display: flex; align-items: center; gap: var(--space-xs); }
  .nav__burger { display: none; }
  /* Drawer is a mobile-only affordance; keep it hidden on desktop even if JS left it open. */
  .nav__drawer { display: none; }

  /* Buffer zone above the burger breakpoint: the full link set (8 items) + lang
     pill + CTA gets tight here, so drop the brand wordmark first to reclaim width
     before anything is forced to wrap/overflow. */
  @media (max-width: 1320px) {
    .nav__word { display: none; }
  }

  @media (max-width: 1200px) {
    .nav__links, .nav__cta { display: none; }
    .nav__actions { margin-inline-start: auto; }
    .nav__burger {
      display: grid; gap: 5px; background: none; border: 0; cursor: pointer; padding: 0.5rem;
    }
    .nav__burger span { width: 24px; height: 2px; background: var(--encre); display: block; }
    .nav__drawer {
      display: grid; gap: var(--space-s); padding: var(--space-l) var(--gutter) var(--space-xl);
      border-bottom: var(--hairline) solid var(--rule); background: var(--calcaire);
    }
    /* The `display: grid` above overrides the UA `[hidden]` rule, so re-assert it:
       without this the drawer is permanently open on mobile and the burger appears dead. */
    .nav__drawer[hidden] { display: none; }
    .nav__drawer a {
      font-family: var(--font-display); font-size: var(--step-2); text-decoration: none;
    }
    .nav__drawer .btn { font-family: var(--font-ui); font-size: var(--step-0); width: max-content; }
  }
</style>

<script>
  const burger = document.querySelector('[data-burger]') as HTMLButtonElement | null;
  const drawer = document.querySelector('[data-drawer]') as HTMLElement | null;

  function openDrawer() {
    if (!drawer || !burger) return;
    burger.setAttribute('aria-expanded', 'true');
    drawer.hidden = false;
    const firstLink = drawer.querySelector('a') as HTMLElement | null;
    firstLink?.focus();
  }

  function closeDrawer({ returnFocus = false } = {}) {
    if (!drawer || !burger) return;
    burger.setAttribute('aria-expanded', 'false');
    drawer.hidden = true;
    if (returnFocus) burger.focus();
  }

  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    if (open) closeDrawer();
    else openDrawer();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    if (burger?.getAttribute('aria-expanded') === 'true') {
      closeDrawer({ returnFocus: true });
    }
  });
</script>
