---
/**
 * DomaineSchematic — architectural line-plan of the estate, redrawn to match the
 * real site (aerial photography + the château's own ground plan): a long
 * Renaissance corps-de-logis ringed by a rectangular moat with four round corner
 * towers, entered from the north across a bridge from the cour d'honneur and the
 * tree-lined allée up to the village gate; a stair descends to the south jardins.
 * La Ferme, Le Verger and Le Bois sit in the surrounding park (diagrammatic).
 * Thin brass/ink strokes on stone — a location-bible plate. North is up.
 * Scroll-triggered stroke "draw-in"; fully disabled under reduced-motion.
 */
import type { Locale } from '../../i18n/ui';
interface Props { locale: Locale }
const { locale } = Astro.props;
const isFr = locale === 'fr';
const aria = isFr
  ? "Plan schématique du domaine, le nord en haut : le château, long corps de logis ceint de douves rectangulaires et flanqué de quatre tours d’angle rondes, franchi au nord par un pont depuis la cour d’honneur et l’allée qui monte à la grille du village ; un escalier descend vers les jardins au sud. La Ferme, le verger et le bois occupent le parc alentour."
  : 'Schematic site plan, north up: the château — a long corps-de-logis ringed by a rectangular moat with four round corner towers — entered from the north by a bridge from the cour d’honneur and the allée rising to the village gate; a stair descends to the south gardens. La Ferme, the orchard and the woods occupy the surrounding park.';
---
<figure class="schematic" data-reveal>
  <svg
    class="schematic__svg"
    viewBox="0 0 920 620"
    role="img"
    aria-label={aria}
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Estate boundary (the enceinte / park edge) -->
    <g id="zone-bounds">
      <rect class="draw-line wall d0" x="20" y="20" width="880" height="580" rx="10" pathLength="1" />
    </g>

    <!-- La Grille + l'allée d'honneur (north approach from the village) -->
    <g id="zone-allee">
      <line class="draw-line d1" x1="444" y1="30" x2="444" y2="46" pathLength="1" />
      <line class="draw-line d1" x1="476" y1="30" x2="476" y2="46" pathLength="1" />
      <text class="label label--sm" x="460" y="22" text-anchor="middle">
        {isFr ? 'LA GRILLE · LÉSIGNY' : 'THE GATE · LÉSIGNY'}
      </text>
      <line class="draw-line d1" x1="438" y1="50" x2="438" y2="202" pathLength="1" />
      <line class="draw-line d1" x1="482" y1="50" x2="482" y2="202" pathLength="1" />
      <g class="trees" aria-hidden="true">
        <circle cx="418" cy="74" r="5" /><circle cx="502" cy="74" r="5" />
        <circle cx="418" cy="112" r="5" /><circle cx="502" cy="112" r="5" />
        <circle cx="418" cy="150" r="5" /><circle cx="502" cy="150" r="5" />
        <circle cx="418" cy="188" r="5" /><circle cx="502" cy="188" r="5" />
      </g>
    </g>

    <!-- Cour d'honneur (forecourt) -->
    <g id="zone-cour">
      <rect class="draw-line cour d2" x="332" y="206" width="256" height="92" pathLength="1" />
      <text class="label" x="460" y="256" text-anchor="middle">{isFr ? 'COUR D’HONNEUR' : 'FORECOURT'}</text>
    </g>

    <!-- Les Douves — the moat ring — and the north bridge -->
    <g id="zone-douves">
      <line class="draw-line d3" x1="450" y1="298" x2="450" y2="332" pathLength="1" />
      <line class="draw-line d3" x1="470" y1="298" x2="470" y2="332" pathLength="1" />
      <rect class="draw-line moat d3" x="300" y="302" width="320" height="208" pathLength="1" />
      <text class="label label--sm" x="636" y="406" text-anchor="middle" transform="rotate(90 636 406)">LES DOUVES</text>
    </g>

    <!-- Le Château — long corps-de-logis, four round corner towers, south stair -->
    <g
      id="zone-chateau"
      class="zone-hit"
      role="button"
      tabindex="0"
      data-domaine-zone="chateau"
      aria-label={isFr ? 'Filtrer l’index sur La Château' : 'Filter the index to The Château'}
    >
      <title>{isFr ? 'Filtrer l’index sur La Château' : 'Filter the index to The Château'}</title>
      <rect class="zone-hitbox" x="308" y="342" width="304" height="140" rx="6" />
      <rect class="draw-line block d5" x="330" y="360" width="260" height="92" pathLength="1" />
      <line class="draw-line inner d6" x1="404" y1="360" x2="404" y2="452" pathLength="1" />
      <line class="draw-line inner d6" x1="460" y1="360" x2="460" y2="452" pathLength="1" />
      <line class="draw-line inner d6" x1="516" y1="360" x2="516" y2="452" pathLength="1" />
      <rect class="draw-line d6" x="447" y="350" width="26" height="12" pathLength="1" />
      <circle class="draw-line tower d5" cx="330" cy="360" r="15" pathLength="1" />
      <circle class="draw-line tower d5" cx="590" cy="360" r="15" pathLength="1" />
      <circle class="draw-line tower d5" cx="330" cy="452" r="15" pathLength="1" />
      <circle class="draw-line tower d5" cx="590" cy="452" r="15" pathLength="1" />
      <g class="steps draw-line d6" aria-hidden="true">
        <line x1="440" y1="458" x2="480" y2="458" pathLength="1" />
        <line x1="444" y1="466" x2="476" y2="466" pathLength="1" />
        <line x1="448" y1="474" x2="472" y2="474" pathLength="1" />
      </g>
      <text class="label label--lg" x="460" y="410" text-anchor="middle">{isFr ? 'LE CHÂTEAU' : 'THE CHÂTEAU'}</text>
    </g>

    <!-- Les Jardins — the south lawns -->
    <g id="zone-jardins">
      <text class="label" x="460" y="550" text-anchor="middle">{isFr ? 'LES JARDINS' : 'THE GARDENS'}</text>
    </g>

    <!-- Le Bois — the western woods -->
    <g id="zone-bois">
      <g class="orchard" aria-hidden="true">
        <circle cx="90" cy="332" r="7" /><circle cx="150" cy="330" r="7" /><circle cx="120" cy="362" r="7" />
        <circle cx="72" cy="362" r="7" /><circle cx="162" cy="398" r="7" /><circle cx="82" cy="392" r="7" />
        <circle cx="130" cy="420" r="7" /><circle cx="100" cy="452" r="7" /><circle cx="152" cy="452" r="7" />
        <circle cx="112" cy="490" r="7" /><circle cx="70" cy="424" r="7" />
      </g>
      <text class="label" x="118" y="306" text-anchor="middle">{isFr ? 'LE BOIS' : 'THE WOODS'}</text>
    </g>

    <!-- La Ferme — courtyard block in the eastern park -->
    <g
      id="zone-ferme"
      class="zone-hit"
      role="button"
      tabindex="0"
      data-domaine-zone="ferme"
      aria-label={isFr ? 'Filtrer l’index sur La Ferme' : 'Filter the index to The Farm'}
    >
      <title>{isFr ? 'Filtrer l’index sur La Ferme' : 'Filter the index to The Farm'}</title>
      <rect class="zone-hitbox" x="684" y="326" width="162" height="150" rx="6" />
      <rect class="draw-line d4" x="690" y="346" width="150" height="120" pathLength="1" />
      <rect class="draw-line cour d4" x="722" y="380" width="86" height="54" pathLength="1" />
      <text class="label" x="765" y="338" text-anchor="middle">{isFr ? 'LA FERME' : 'THE FARM'}</text>
      <text class="label label--sm" x="765" y="411" text-anchor="middle">{isFr ? 'COUR' : 'YARD'}</text>
    </g>

    <!-- Le Verger — orchard grid, south-east -->
    <g id="zone-verger">
      <g class="orchard" aria-hidden="true">
        <circle cx="700" cy="522" r="6" /><circle cx="738" cy="522" r="6" /><circle cx="776" cy="522" r="6" /><circle cx="814" cy="522" r="6" />
        <circle cx="700" cy="558" r="6" /><circle cx="738" cy="558" r="6" /><circle cx="776" cy="558" r="6" /><circle cx="814" cy="558" r="6" />
      </g>
      <text class="label" x="757" y="506" text-anchor="middle">{isFr ? 'LE VERGER' : 'THE ORCHARD'}</text>
    </g>

    <!-- Compass — north is up -->
    <g id="compass" class="compass" aria-hidden="true">
      <line class="draw-line d1" x1="850" y1="112" x2="850" y2="66" pathLength="1" />
      <path class="needle" d="M850 60 L844 78 L850 72 L856 78 Z" />
      <text class="label label--sm" x="850" y="128" text-anchor="middle">N</text>
    </g>

    <!-- Scale bar -->
    <g id="scale" class="scale" aria-hidden="true">
      <line class="draw-line d2" x1="80" y1="560" x2="240" y2="560" pathLength="1" />
      <line class="draw-line d2" x1="80" y1="555" x2="80" y2="565" pathLength="1" />
      <line class="draw-line d2" x1="160" y1="555" x2="160" y2="565" pathLength="1" />
      <line class="draw-line d2" x1="240" y1="555" x2="240" y2="565" pathLength="1" />
      <text class="label label--sm" x="80" y="578" text-anchor="start">0</text>
      <text class="label label--sm" x="240" y="578" text-anchor="end">100 M</text>
    </g>
  </svg>
  <p class="schematic__hint slate" aria-hidden="true">
    {isFr ? 'Cliquez sur le château ou sur la ferme pour filtrer les décors ci-dessous.' : 'Click the château or the farm to filter the décors below.'}
  </p>
</figure>

<script>
  // Clickable estate map: each interactive zone filters the décor index (a
  // separate component) via a document-level CustomEvent. Keyboard-operable.
  // With JS off, the zones are inert plain SVG (no regression).
  const zones = document.querySelectorAll<SVGGElement>('[data-domaine-zone]');
  for (const z of zones) {
    const value = z.getAttribute('data-domaine-zone') ?? 'tous';
    const fire = () =>
      document.dispatchEvent(new CustomEvent('domaine:filter', { detail: { group: 'space', value } }));
    z.addEventListener('click', fire);
    z.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        fire();
      }
    });
  }
</script>

<style>
  .schematic {
    margin: 0;
    background:
      radial-gradient(120% 90% at 50% 0%, var(--calcaire), transparent 70%),
      var(--pierre);
    border: var(--hairline) solid var(--rule);
    border-radius: var(--radius-m);
    padding: clamp(1rem, 4vw, var(--space-xl));
    /* On narrow screens the plan becomes a self-contained horizontal-scroll
       region rather than shrinking its labels into illegibility. */
    overflow-x: auto;
  }
  .schematic__svg { width: 100%; height: auto; overflow: visible; min-width: 660px; }

  /* --- Interactive zones (clickable estate map) --- */
  .zone-hitbox { fill: transparent; pointer-events: all; }
  .zone-hit { cursor: pointer; }
  .zone-hit:hover .label,
  .zone-hit:focus-visible .label { fill: var(--sang); }
  .zone-hit:hover .block,
  .zone-hit:hover .d4 { stroke: var(--sang); }
  .zone-hit:focus-visible { outline: 2px solid var(--laiton-deep); outline-offset: 3px; border-radius: 4px; }
  .zone-hit:focus { outline: none; } /* only show ring for keyboard focus */

  .schematic__hint {
    text-align: center;
    font-size: var(--step--1);
    color: var(--text-muted);
    margin-top: var(--space-s);
  }
  @media (prefers-reduced-motion: no-preference) {
    .zone-hit .label { transition: fill var(--dur-fast) var(--ease-soft); }
  }

  /* --- Strokes --- */
  .draw-line {
    fill: none;
    stroke: var(--encre-soft);
    stroke-width: 1.25;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }
  .wall  { stroke: color-mix(in srgb, var(--encre-soft) 55%, transparent); stroke-dasharray: 3 7; }
  .moat  { stroke: var(--laiton); stroke-width: 1.6; }
  .cour  { stroke: color-mix(in srgb, var(--encre-soft) 55%, transparent); }
  .block { stroke: var(--encre); stroke-width: 1.7; }
  .inner { stroke: color-mix(in srgb, var(--encre-soft) 55%, transparent); stroke-width: 1; }
  .tower { fill: var(--pierre); stroke: var(--encre); stroke-width: 1.5; }
  .steps line { stroke-width: 1; }
  .needle { fill: var(--sang); }

  /* --- Plantings / decorative dots --- */
  .trees circle   { fill: var(--laiton); opacity: 0.6; }
  .orchard circle { fill: none; stroke: var(--laiton); stroke-width: 1; vector-effect: non-scaling-stroke; opacity: 0.8; }

  /* --- Labels (Geist Mono) --- */
  .label {
    font-family: var(--font-slate);
    font-size: 13px;
    letter-spacing: 0.06em;
    fill: var(--encre-soft);
  }
  .label--sm { font-size: 11px; fill: color-mix(in srgb, var(--encre-soft) 80%, transparent); }
  .label--lg { font-size: 15px; fill: var(--encre); letter-spacing: 0.04em; }

  /* --- Draw-in: keyed off the reveal observer adding .is-in --- */
  .schematic.is-in .draw-line {
    animation: drawIn var(--dur-slow) var(--ease-cut) both;
  }
  .schematic.is-in .d1 { animation-delay: 120ms; }
  .schematic.is-in .d2 { animation-delay: 220ms; }
  .schematic.is-in .d3 { animation-delay: 340ms; }
  .schematic.is-in .d4 { animation-delay: 440ms; }
  .schematic.is-in .d5 { animation-delay: 560ms; }
  .schematic.is-in .d6 { animation-delay: 700ms; }

  @keyframes drawIn {
    from { stroke-dasharray: 1; stroke-dashoffset: 1; }
    to   { stroke-dasharray: 1; stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .schematic.is-in .draw-line { animation: none; }
  }
</style>
