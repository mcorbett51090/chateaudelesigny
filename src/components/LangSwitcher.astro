---
import { type Locale, useT, withLocale, localeFromPath } from '../i18n/ui';
const current: Locale = localeFromPath(Astro.url.pathname);
const t = useT(current);
const target: Locale = current === 'fr' ? 'en' : 'fr';
const href = withLocale(Astro.url.pathname, target);
---
<a class="lang" href={href} hreflang={target} aria-label={t('lang.label')}>
  <span aria-hidden="true" class="lang__code">{target.toUpperCase()}</span>
  <span class="visually-hidden">{t('lang.switch')}</span>
</a>
<style>
  .lang {
    font-family: var(--font-ui);
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-decoration: none;
    padding: 0.4em 0.6em;
    border-radius: var(--radius-s);
    box-shadow: inset 0 0 0 1px var(--rule);
    transition: box-shadow var(--dur-fast) var(--ease-soft);
  }
  .lang:hover { box-shadow: inset 0 0 0 1px var(--laiton); }
</style>
