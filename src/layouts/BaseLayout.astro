---
import '../styles/global.css';
import { getImage } from 'astro:assets';
import { site } from '../config/site';
import { photos } from '../assets/images';
import { type Locale, useT, withLocale, withBase } from '../i18n/ui';
import { siteOrigin, venueNode, jsonLdScript } from '../lib/schema';
import { features } from '../config/features';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  /** Path WITHOUT locale prefix, e.g. 'mariages/' or '' for home. Used for hreflang. */
  path?: string;
  dark?: boolean;
  image?: string;
  /** Extra JSON-LD nodes for this page (e.g. FAQPage, Product, LodgingBusiness).
   *  Merged into ONE @graph with the canonical venue node — no duplicate entities. */
  jsonLd?: object[];
  /** Emit robots noindex (e.g. legal pages carrying unfilled TODO placeholders). */
  noindex?: boolean;
  /** Image key (from images.ts) to use as this page's og:image, so social shares
   *  differ per page. Resolved to an absolute JPG. `image` (a full URL) overrides it. */
  ogImageKey?: string;
}

const { title, description, locale, path = '', dark = false, image, jsonLd = [], noindex = false, ogImageKey } = Astro.props;
const t = useT(locale);

// withLocale() already includes the deployment base; canonical/og must add it explicitly.
const canonical = new URL(withBase(`${locale}/${path}`), Astro.site).href;
const altFr = new URL(withLocale(`/${locale}/${path}`, 'fr'), Astro.site).href;
const altEn = new URL(withLocale(`/${locale}/${path}`, 'en'), Astro.site).href;
// og:image priority: explicit `image` URL → resolved `ogImageKey` photo → site default.
let ogImage = image ?? new URL(withBase('/og/default.png'), Astro.site).href;
if (!image && ogImageKey && photos[ogImageKey]) {
  const og = await getImage({ src: photos[ogImageKey], width: 1200, format: 'jpg' });
  ogImage = new URL(og.src, Astro.site).href;
}

// One canonical LocalBusiness+EventVenue entity (stable @id) + any per-page nodes,
// serialized into a single <script> @graph. Replaces the old TouristAttraction-only block.
const origin = siteOrigin(Astro.site, import.meta.env.BASE_URL);
// The venue node carries a FIXED site-level description (not this page's meta
// description) so its single @id never holds conflicting values across the graph.
const venueDescription = locale === 'fr' ? site.tagline.fr : site.tagline.en;
const ldScript = jsonLdScript([venueNode(origin, venueDescription, ogImage), ...jsonLd]);
---

<!doctype html>
<html lang={locale} class={dark ? 'is-dark' : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="fr" href={altFr} />
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="x-default" href={altFr} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#1a1714" />
    <link rel="icon" href={withBase('/crest-lesigny.svg')} type="image/svg+xml" />

    {/* Cookieless, privacy-friendly analytics — no cookies, no PII, no consent
        banner required (CNIL audience-measurement exemption). Emitted only when
        a token/domain is configured. */}
    {features.cloudflareBeacon && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${features.cloudflareBeacon}"}`}
      ></script>
    )}
    {features.plausibleDomain && (
      <script defer data-domain={features.plausibleDomain} src="https://plausible.io/js/script.js"></script>
    )}
    <!-- No-JS fallback: reveal-on-scroll elements must not stay hidden without JS. -->
    <noscript><style>[data-reveal]{opacity:1 !important;transform:none !important;}</style></noscript>
    <Fragment set:html={ldScript} />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('skip')}</a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />

    <script>
      // Lightweight scroll-reveal — no library. Honors reduced-motion via CSS.
      const els = document.querySelectorAll('[data-reveal]');
      if (els.length && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-in'));
      }
    </script>
  </body>
</html>
