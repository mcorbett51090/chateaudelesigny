        phones: ['+33 1 43 60 44 97'],
        email: 'contact@traiteur-lesenfantsterribles.fr',
        website: {
          label: 'traiteur-lesenfantsterribles.fr',
          url: 'https://www.traiteur-lesenfantsterribles.fr',
        },
      },
      {
        slug: 'aviv-saveurs',
        name: 'Aviv Saveurs',
        photo: 'partner-aviv-saveurs',
