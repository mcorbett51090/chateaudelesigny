---
import PageLayout from '../../layouts/PageLayout.astro';
import Photo from '../../components/Photo.astro';
import { site } from '../../config/site';
import { locales, type Locale, useT, localeBase } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useT(locale);
const base = localeBase(locale);
const isFr = locale === 'fr';

const eventTypes = [
  { fr: 'Réceptions d’entreprise', en: 'Corporate receptions' },
  { fr: 'Séminaires', en: 'Seminars' },
  { fr: 'Galas', en: 'Galas' },
  { fr: 'Team-building', en: 'Team-building' },
  { fr: 'Célébrations annuelles', en: 'Annual celebrations' },
  { fr: 'Inaugurations', en: 'Inaugurations' },
];

// Room capacity matrix (mirrored from the original Company Events page).
// null = configuration not offered for that room.
const configs = [
  { key: 'theatre', fr: 'Théâtre', en: 'Theatre' },
  { key: 'classe', fr: 'Classe', en: 'Classroom' },
  { key: 'u', fr: 'En U', en: 'U-shape' },
  { key: 'diner', fr: 'Dîner', en: 'Dinner' },
  { key: 'cocktail', fr: 'Cocktail', en: 'Cocktail' },
] as const;

const rooms: { fr: string; en: string; caps: Record<string, number | null> }[] = [
  { fr: 'Salon Médicis', en: 'Médicis Salon', caps: { theatre: 42, classe: 30, u: 12, diner: 40, cocktail: 150 } },
  { fr: 'Salon Boisé', en: 'Boisé Salon', caps: { theatre: 30, classe: 20, u: null, diner: 32, cocktail: 80 } },
  { fr: 'Salon Gris', en: 'Grey Salon', caps: { theatre: 40, classe: null, u: null, diner: 60, cocktail: 200 } },
  { fr: 'Escalier d’Honneur', en: 'Grand Staircase', caps: { theatre: 60, classe: 60, u: null, diner: null, cocktail: 120 } },
];

const activities = [
  {
    fr: 'Activités sportives',
    en: 'Sports activities',
    frDesc: 'Défis en équipe et challenges dans le parc de 54 hectares.',
    enDesc: 'Team challenges and outdoor events across the 54-hectare park.',
  },
  {
    fr: 'Activités créatives',
    en: 'Creative activities',
    frDesc: 'Ateliers et animations sur mesure dans les salons du château.',
    enDesc: 'Bespoke workshops and activities within the château salons.',
  },
  {
    fr: 'Soirées à thème',
    en: 'Themed evenings',
    frDesc: 'Dîners et soirées scénarisés dans un décor Renaissance.',
    enDesc: 'Scripted dinners and evenings in a Renaissance setting.',
  },
];
---

<PageLayout
  title={isFr
    ? 'Séminaires & événements · Château de Lésigny'
    : 'Corporate events & seminars · Château de Lésigny'}
  description={isFr
    ? 'Séminaires, team-building, galas et réceptions d’entreprise au Château de Lésigny — salons modulables à 24 km de Paris, dans un parc boisé de 54 hectares.'
    : 'Seminars, team-building, galas and corporate receptions at Château de Lésigny — adaptable salons 24 km from Paris, in a 54-hectare wooded park.'}
  locale={locale}
  path="entreprise/"
>

  <!-- ① Hero ---------------------------------------------------------------- -->
  <section class="en-hero is-dark" aria-labelledby="en-h1">
    <Photo
      fill
      name="event-cocktail"
      alt={isFr ? 'Cocktail d’entreprise dans les salons du Château de Lésigny' : 'Corporate cocktail reception in the salons of Château de Lésigny'}
      loading="eager"
      fetchpriority="high"
      sizes="100vw"
      widths={[800, 1600, 2400]}
    />
    <div class="en-hero__scrim" aria-hidden="true"></div>
    <div class="wrap-wide en-hero__inner">
      <p class="eyebrow en-hero__eyebrow" data-reveal>
        {isFr ? 'Événements d’entreprise' : 'Corporate events'}
      </p>
      <h1 id="en-h1" class="en-hero__title" data-reveal>
        {isFr
          ? 'Réunissez vos équipes dans un cadre d’exception.'
          : 'Bring your teams together in an exceptional setting.'}
      </h1>
      <p class="en-hero__lede" data-reveal>
        {isFr
          ? `À ${site.address.fromParisKm} km de Paris, à l’abri d’une forêt environnante, le château accueille séminaires, journées de team-building, célébrations annuelles, galas et inaugurations. Nos salons entièrement modulables se configurent selon chaque format.`
          : `${site.address.fromParisKm} km from Paris, sheltered by surrounding forest, the château hosts seminars, team-building days, annual celebrations, galas and inaugurations. Our fully adaptable salons configure to any format.`}
      </p>
      <div class="en-hero__actions" data-reveal>
        <a class="btn btn--primary" href={`${base}/contact/?stream=corporate`}>
          {isFr ? 'Demander un devis' : 'Request a quote'}
        </a>
        <a class="btn btn--ghost" href="#capacites">
          {isFr ? 'Voir les capacités' : 'See capacities'}
        </a>
      </div>
    </div>
  </section>

  <!-- ② Event types --------------------------------------------------------- -->
  <section class="section en-types" aria-labelledby="en-types-h2">
    <div class="wrap-wide">
      <div class="en-types__header" data-reveal>
        <p class="eyebrow">{isFr ? 'Votre événement au château' : 'Your event at the château'}</p>
        <h2 id="en-types-h2">
          {isFr ? 'Un format pour chaque occasion professionnelle.' : 'A format for every professional occasion.'}
        </h2>
      </div>
      <ul class="en-types__grid" role="list">
        {eventTypes.map((ev) => (
          <li class="en-type" data-reveal>{isFr ? ev.fr : ev.en}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ③ Capacities matrix --------------------------------------------------- -->
  <section class="section en-caps is-dark" id="capacites" aria-labelledby="en-caps-h2">
    <div class="wrap-wide">
      <div class="en-caps__header" data-reveal>
        <p class="eyebrow">{isFr ? 'Nos espaces' : 'Our spaces'}</p>
        <h2 id="en-caps-h2">
          {isFr ? 'Capacité de nos salons' : 'Capacity of our salons'}
        </h2>
        <p class="en-caps__lede slate">
          {isFr
            ? 'Nombre d’invités par salon selon la configuration retenue.'
            : 'Guest numbers per salon by chosen configuration.'}
        </p>
      </div>

      <div class="en-table-wrap" data-reveal>
        <table class="en-table">
          <thead>
            <tr>
              <th scope="col">{isFr ? 'Salon' : 'Salon'}</th>
              {configs.map((c) => <th scope="col">{isFr ? c.fr : c.en}</th>)}
            </tr>
          </thead>
          <tbody>
            {rooms.map((room) => (
              <tr>
                <th scope="row">{isFr ? room.fr : room.en}</th>
                {configs.map((c) => (
                  <td>
                    {room.caps[c.key] != null
                      ? room.caps[c.key]
                      : <span class="en-table__na" aria-label={isFr ? 'Non proposé' : 'Not offered'}>—</span>}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ④ Activities ---------------------------------------------------------- -->
  <section class="section en-activities" aria-labelledby="en-act-h2">
    <div class="wrap-wide">
      <div class="en-activities__header" data-reveal>
        <p class="eyebrow">{isFr ? 'Animations' : 'Activities'}</p>
        <h2 id="en-act-h2">
          {isFr ? 'Rythmez votre journée.' : 'Shape your day.'}
        </h2>
      </div>
      <ul class="en-activities__grid" role="list">
        {activities.map((a, i) => (
          <li class="en-activity" data-reveal>
            <span class="en-activity__n slate" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="en-activity__title">{isFr ? a.fr : a.en}</h3>
            <p class="en-activity__desc">{isFr ? a.frDesc : a.enDesc}</p>
          </li>
        ))}
      </ul>
      <p class="en-activities__partners" data-reveal>
        <a class="en-link" href={`${base}/partenaires/`}>
          {isFr ? 'Découvrir nos prestataires partenaires →' : 'Discover our partner suppliers →'}
        </a>
      </p>
    </div>
  </section>

  <!-- ⑤ CTA ----------------------------------------------------------------- -->
  <section class="en-cta is-dark" aria-labelledby="en-cta-h2">
    <Photo
      fill
      duotone
      name="int-grand-hall"
      alt={isFr ? 'Grande salle du château dressée pour un événement d’entreprise' : 'Château grand hall set for a corporate event'}
    />
    <div class="en-cta__scrim" aria-hidden="true"></div>
    <div class="wrap en-cta__inner" data-reveal>
      <p class="eyebrow">{isFr ? 'Organisons votre événement' : 'Let’s plan your event'}</p>
      <h2 id="en-cta-h2" class="en-cta__title">
        {isFr
          ? 'Un séminaire dont vos équipes se souviendront.'
          : 'A seminar your teams will remember.'}
      </h2>
      <div class="en-cta__actions">
        <a class="btn btn--primary" href={`${base}/contact/?stream=corporate`}>
          {isFr ? 'Demander un devis' : 'Request a quote'}
        </a>
      </div>
      <p class="en-cta__phone-wrap">
        <a class="en-cta__phone" href={`tel:${site.contact.phoneEvents.replace(/\s/g, '')}`}>
          {site.contact.phoneEvents}
        </a>
      </p>
    </div>
  </section>

</PageLayout>

<style>
  /* =========================================================================
     Séminaires & événements d'entreprise — page-scoped styles (tokens only)
     ========================================================================= */

  /* --- ① Hero -------------------------------------------------------------- */
  .en-hero {
    position: relative;
    overflow: hidden;
    background: var(--suie);
    padding-block: clamp(4rem, 13vh, 10rem) var(--space-l);
  }
  .en-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      170deg,
      color-mix(in srgb, var(--encre) 62%, transparent) 0%,
      color-mix(in srgb, var(--encre) 52%, transparent) 100%
    );
  }
  .en-hero__inner { position: relative; z-index: 2; }
  .en-hero__eyebrow { margin-bottom: var(--space-m); }
  .en-hero__title { font-size: var(--step-5); max-width: 20ch; margin-bottom: var(--space-m); }
  .en-hero__lede {
    font-size: var(--step-1);
    color: var(--text-muted);
    max-width: 56ch;
    margin-bottom: var(--space-l);
  }
  .en-hero__actions { display: flex; gap: var(--space-s); flex-wrap: wrap; }
  .en-hero .btn--ghost { color: var(--ivoire); }

  /* --- ② Event types ------------------------------------------------------- */
  .en-types__header { max-width: var(--measure); margin-bottom: var(--space-xl); }
  .en-types__header h2 { margin-top: var(--space-3xs); }
  .en-types__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-m) var(--space-l);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .en-type {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 460;
    color: var(--text);
    padding-top: var(--space-s);
    border-top: var(--hairline) solid var(--rule);
  }

  /* --- ③ Capacities -------------------------------------------------------- */
  .en-caps { background: var(--suie); }
  .en-caps__header { max-width: var(--measure); margin-bottom: var(--space-xl); }
  .en-caps__header h2 { margin-top: var(--space-3xs); }
  .en-caps__lede { margin-top: var(--space-2xs); color: var(--text-muted); }

  .en-table-wrap { overflow-x: auto; }
  .en-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-ui);
    min-width: 640px;
  }
  .en-table th,
  .en-table td {
    padding: var(--space-s) var(--space-m);
    text-align: center;
    border-bottom: var(--hairline) solid color-mix(in srgb, var(--laiton) 30%, transparent);
  }
  .en-table thead th {
    font-size: var(--step--1);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--laiton-soft);
    font-weight: 600;
    border-bottom: var(--hairline) solid var(--laiton);
  }
  .en-table thead th:first-child,
  .en-table tbody th {
    text-align: left;
  }
  .en-table tbody th {
    font-family: var(--font-display);
    font-size: var(--step-0);
    font-weight: 460;
    color: var(--ivoire);
    white-space: nowrap;
  }
  .en-table tbody td {
    font-size: var(--step-0);
    color: var(--ivoire);
    font-variant-numeric: tabular-nums;
  }
  .en-table__na { color: color-mix(in srgb, var(--ivoire) 40%, transparent); }

  /* --- ④ Activities -------------------------------------------------------- */
  .en-activities__header { max-width: var(--measure); margin-bottom: var(--space-xl); }
  .en-activities__header h2 { margin-top: var(--space-3xs); }
  .en-activities__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l) var(--space-xl);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .en-activity {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding-top: var(--space-m);
    border-top: var(--hairline) solid var(--rule);
  }
  .en-activity__n { font-size: var(--step--1); letter-spacing: 0.12em; }
  .en-activity__title { font-size: var(--step-1); font-weight: 460; margin-top: var(--space-3xs); }
  .en-activity__desc { color: var(--text-muted); font-size: var(--step--1); max-width: none; }
  .en-activities__partners { margin-top: var(--space-xl); }
  .en-link {
    font-family: var(--font-ui);
    font-size: var(--step-0);
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    border-bottom: var(--hairline) solid var(--laiton);
    padding-bottom: 2px;
    transition: color var(--dur-fast) var(--ease-soft), border-color var(--dur-fast) var(--ease-soft);
  }
  .en-link:hover { color: var(--sang); border-color: var(--sang); }

  /* --- ⑤ CTA --------------------------------------------------------------- */
  .en-cta {
    position: relative;
    overflow: hidden;
    background: var(--suie);
    padding-block: var(--space-3xl);
  }
  .en-cta__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--encre) 68%, transparent) 0%,
      color-mix(in srgb, var(--encre) 74%, transparent) 100%
    );
  }
  .en-cta__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-m);
  }
  .en-cta__title { max-width: 22ch; font-size: var(--step-4); color: var(--ivoire); }
  .en-cta__actions { margin-top: var(--space-s); }
  .en-cta__phone-wrap { max-width: none; }
  .en-cta__phone {
    font-family: var(--font-slate);
    font-size: var(--step-1);
    letter-spacing: 0.05em;
    color: var(--laiton-soft);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .en-cta__phone:hover { color: var(--ivoire); }

  /* --- Responsive ---------------------------------------------------------- */
  @media (max-width: 820px) {
    .en-types__grid { grid-template-columns: repeat(2, 1fr); }
    .en-activities__grid { grid-template-columns: 1fr; gap: var(--space-l); }
    .en-cta__title { font-size: var(--step-3); }
  }
  @media (max-width: 540px) {
    .en-hero__title { font-size: var(--step-4); }
    .en-types__grid { grid-template-columns: 1fr; }
  }
</style>
