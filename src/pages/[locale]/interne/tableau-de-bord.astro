---
import PageLayout from '../../../layouts/PageLayout.astro';
import { locales, type Locale } from '../../../i18n/ui';
import { readdirSync, readFileSync } from 'node:fs';

// No-login analytics dashboard. Month-by-month time series from the committed snapshots
// (reports/analytics/YYYY-MM.json), with: timeframe controls, a multi-select metric overlay
// (each line scaled to its own range), and user-managed EVENT annotations (renovations, launches…)
// shown as labeled vertical lines you can toggle. Events seed from reports/analytics/events.json
// and can be added live (stored per-browser in localStorage). noindex + sitemap-excluded.
export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}
const { locale } = Astro.params as { locale: Locale };
const isFr = locale === 'fr';

const STREAMS = ['mariage', 'entreprise', 'sejour', 'boutique', 'cadeau'];
type Point = { month: string; visits: number; conversions: Record<string, number> };
const normConv = (c: any): Record<string, number> =>
  Object.fromEntries(STREAMS.map((k) => [k, typeof c?.[k] === 'number' ? c[k] : (c?.[k]?.merci ?? 0)]));

const dir = 'reports/analytics';
let series: Point[] = [];
let data: any = null;
let events: { date: string; label: string }[] = [];
let isSample = true;
try {
  const files = readdirSync(dir).filter((f) => f.endsWith('.json'));
  const real = files.filter((f) => /^\d{4}-\d{2}\.json$/.test(f)).sort();
  if (real.length) {
    isSample = false;
    const snaps = real.map((f) => JSON.parse(readFileSync(`${dir}/${f}`, 'utf8')));
    series = snaps.map((s) => ({ month: s.month, visits: s.totals?.visits ?? 0, conversions: normConv(s.conversions) }));
    data = snaps[snaps.length - 1];
  } else {
    data = JSON.parse(readFileSync(`${dir}/sample.json`, 'utf8'));
    series = (data.history ?? []).map((h: any) => ({ month: h.month, visits: h.visits, conversions: normConv(h.conversions) }));
  }
} catch { /* no data */ }
try { events = JSON.parse(readFileSync(`${dir}/events.json`, 'utf8')); } catch { /* none */ }

const METRICS = [
  { key: 'visits', label: isFr ? 'Visites' : 'Visits', color: '#7a2e2e' },
  { key: 'mariage', label: isFr ? 'Mariages' : 'Weddings', color: '#b8912f' },
  { key: 'entreprise', label: isFr ? 'Entreprise' : 'Corporate', color: '#2f6f8f' },
  { key: 'sejour', label: isFr ? 'Séjours' : 'Stays', color: '#3f7d55' },
  { key: 'boutique', label: isFr ? 'Boutique' : 'Shop', color: '#6a4f8f' },
  { key: 'cadeau', label: isFr ? 'Bons cadeaux' : 'Vouchers', color: '#9c6b3f' },
];

const channels: { source: string; visits: number }[] = data?.channels ?? [];
const chMax = Math.max(1, ...channels.map((c) => c.visits));
const landing: { path: string; visits: number }[] = data?.landingPages ?? [];
const conv: Record<string, { merci: number; confirmed: number | null }> = data?.conversions ?? {};
const streamLabel: Record<string, string> = isFr
  ? { mariage: 'Mariages', entreprise: 'Entreprise', sejour: 'Séjours', boutique: 'Boutique', cadeau: 'Bons cadeaux' }
  : { mariage: 'Weddings', entreprise: 'Corporate', sejour: 'Stays', boutique: 'Shop', cadeau: 'Gift vouchers' };
const fmt = (n: number) => new Intl.NumberFormat(isFr ? 'fr-FR' : 'en-US').format(n);
const title = `${isFr ? 'Tableau de bord' : 'Dashboard'} · Château de Lésigny`;
---
<PageLayout title={title} description={isFr ? 'Tableau de bord d’audience du site.' : 'Website audience dashboard.'} locale={locale} path="interne/tableau-de-bord/" noindex={true}>
  <section class="db section">
    <div class="wrap">
      <p class="eyebrow" data-reveal>{isFr ? 'Interne · Audience du site' : 'Internal · Site audience'}</p>
      <h1 data-reveal>{isFr ? 'Tableau de bord' : 'Dashboard'}</h1>
      <p class="db__meta slate" data-reveal>
        {isSample
          ? (isFr ? 'Données d’exemple — en attente de l’activation de Cloudflare.' : 'Sample data — awaiting Cloudflare activation.')
          : (isFr ? `Dernière période : ${data?.month}` : `Latest period: ${data?.month}`)}
        {data?.sampleNote ? ` · ${data.sampleNote}` : ''}
      </p>

      {series.length > 0 && (
        <div class="db__trend" data-reveal>
          <div class="db__controls">
            <div class="db__legend" role="group" aria-label={isFr ? 'Mesures (choix multiple)' : 'Metrics (multi-select)'}>
              {METRICS.map((m, i) => (
                <button type="button" class={`db__chip${i === 0 ? ' is-on' : ''}`} data-metric={m.key} data-label={m.label} aria-pressed={i === 0 ? 'true' : 'false'} style={`--c:${m.color}`}>
                  <span class="db__swatch" aria-hidden="true"></span>
                  <span class="db__chip-l">{m.label}</span>
                  <span class="db__lv" data-lv={m.key}></span>
                </button>
              ))}
            </div>
            <div class="db__seg" role="group" aria-label={isFr ? 'Période' : 'Timeframe'} data-role="tf">
              <button type="button" data-tf="3">3M</button>
              <button type="button" data-tf="6">6M</button>
              <button type="button" data-tf="12">12M</button>
              <button type="button" data-tf="0" class="is-on">{isFr ? 'Tout' : 'All'}</button>
            </div>
          </div>
          <p class="db__sum" id="db-sum" aria-live="polite"></p>

          <div class="db__main">
            <div class="db__chartcol">
              <div class="db__chart" id="db-chart" role="img" aria-label={isFr ? 'Graphique de tendance' : 'Trend chart'}></div>
              <p class="db__hint slate">{isFr ? 'Cliquez une mesure pour l’ajouter/retirer. Chaque courbe est à l’échelle de sa propre plage — comparez les tendances. Chiffres échantillonnés.' : 'Click a metric to add/remove it. Each line is scaled to its own range — compare trends. Sampled figures.'}</p>
            </div>

            <aside class="db__events" aria-label={isFr ? 'Événements' : 'Events'}>
              <div class="db__ev-head">
                <span>{isFr ? 'Événements' : 'Events'}</span>
                <button type="button" id="db-ev-all" class="db__ev-all">{isFr ? 'Tout' : 'All'}</button>
              </div>
              <ul class="db__ev-list" id="db-ev-list"></ul>
              <form class="db__ev-add" id="db-ev-add">
                <input type="month" id="db-ev-date" required aria-label={isFr ? 'Date' : 'Date'} />
                <input type="text" id="db-ev-label" required maxlength="40" placeholder={isFr ? 'Ex : Salle de bal rénovée' : 'e.g. Ballroom renovated'} aria-label={isFr ? 'Intitulé' : 'Label'} />
                <button type="submit">{isFr ? '+ Ajouter' : '+ Add'}</button>
              </form>
              <p class="db__ev-status slate" id="db-ev-status" aria-live="polite"></p>
              <details class="db__ev-sync">
                <summary>{isFr ? '⚙ Enregistrer sur le site' : '⚙ Save to the site'}</summary>
                <p class="db__ev-syncnote slate">
                  {isFr
                    ? 'Collez un jeton GitHub « fine-grained » (autorisation Contents : lecture/écriture, sur ce dépôt uniquement). Il reste dans CE navigateur — jamais publié. Les événements deviennent alors visibles par tous (~1 min après enregistrement).'
                    : 'Paste a fine-grained GitHub token (Contents: read/write, this repo only). It stays in THIS browser — never published. Events then become visible to everyone (~1 min after saving).'}
                </p>
                <div class="db__ev-tok">
                  <input type="password" id="db-gh-token" placeholder="github_pat_…" autocomplete="off" aria-label="GitHub token" />
                  <button type="button" id="db-gh-save">OK</button>
                </div>
              </details>
            </aside>
          </div>
        </div>
      )}

      <div class="db__grid" data-reveal>
        <article class="db__card">
          <p class="db__k">{isFr ? 'D’où viennent les visiteurs' : 'Where visitors come from'}</p>
          <ul class="db__bars">
            {channels.map((c) => (
              <li>
                <span class="db__bar-l">{c.source}</span>
                <span class="db__bar"><span style={`width:${Math.round((c.visits / chMax) * 100)}%`}></span></span>
                <span class="db__bar-n">{fmt(c.visits)}</span>
              </li>
            ))}
          </ul>
        </article>
        <article class="db__card">
          <p class="db__k">{isFr ? 'Conversions — dernier mois (estimation)' : 'Conversions — latest month (estimate)'}</p>
          <ul class="db__conv">
            {Object.keys(streamLabel).map((k) => (
              <li>
                <span>{streamLabel[k]}</span>
                <span class="db__conv-n">
                  {conv[k]?.confirmed ?? conv[k]?.merci ?? 0}
                  {(conv[k]?.confirmed == null && (conv[k]?.merci ?? 0) < 50) && (
                    <span class="db__flag" title={isFr ? 'Petit échantillon — tendance seulement' : 'Small sample — directional only'}>≈</span>
                  )}
                </span>
              </li>
            ))}
          </ul>
          <p class="db__note slate">{isFr ? 'Chiffres réels = votre boîte mail + Stripe. Ici : tendance.' : 'True counts = your inbox + Stripe. Here: the trend.'}</p>
        </article>
        <article class="db__card">
          <p class="db__k">{isFr ? 'Pages d’entrée' : 'Top landing pages'}</p>
          <ul class="db__pages">
            {landing.map((p) => (<li><code>{p.path}</code><span>{fmt(p.visits)}</span></li>))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <script type="application/json" id="db-series" set:html={JSON.stringify(series)} is:inline></script>
  <script type="application/json" id="db-events-seed" set:html={JSON.stringify(events)} is:inline></script>
  <script>
    (() => {
      const $ = (id) => document.getElementById(id);
      const seriesEl = $('db-series'), chart = $('db-chart'), sumEl = $('db-sum');
      const trend = chart?.closest('.db__trend');
      if (!seriesEl || !chart || !sumEl || !trend) return;
      const series = JSON.parse(seriesEl.textContent || '[]');
      if (!series.length) return;
      const isFr = document.documentElement.lang === 'fr';
      const nf = new Intl.NumberFormat(isFr ? 'fr-FR' : 'en-US');
      const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

      const COLORS = { visits: '#7a2e2e', mariage: '#b8912f', entreprise: '#2f6f8f', sejour: '#3f7d55', boutique: '#6a4f8f', cadeau: '#9c6b3f' };
      const fnMap = {
        visits: (s) => s.visits, mariage: (s) => s.conversions.mariage, entreprise: (s) => s.conversions.entreprise,
        sejour: (s) => s.conversions.sejour, boutique: (s) => s.conversions.boutique, cadeau: (s) => s.conversions.cadeau,
      };
      const chips = Array.from(trend.querySelectorAll('.db__chip'));
      const label = {};
      chips.forEach((b) => { label[b.dataset.metric] = b.dataset.label; });
      const order = chips.map((b) => b.dataset.metric);
      const selected = new Set(['visits']);
      let tf = 0;

      // ---- Events (seed from committed file + local additions; optional commit back to repo) ----
      const LS_ADD = 'db-events-add', LS_OFF = 'db-events-off', LS_DEL = 'db-events-del', LS_TOK = 'db-gh-token';
      const load = (k, d) => { try { return JSON.parse(localStorage.getItem(k)) || d; } catch { return d; } };
      const save = (k, v) => { try { localStorage.setItem(k, JSON.stringify(v)); } catch {} };
      const seed = JSON.parse($('db-events-seed')?.textContent || '[]').map((e) => ({ ...e, user: false }));
      const evId = (e) => e.date + '|' + e.label;
      // Prune local additions that have since been committed to the file (now in seed).
      const seedIds = new Set(seed.map(evId));
      let userEv = load(LS_ADD, []).filter((e) => !seedIds.has(evId(e))).map((e) => ({ ...e, user: true }));
      save(LS_ADD, userEv.map(({ user, ...r }) => r));
      let off = new Set(load(LS_OFF, []));
      let deleted = new Set(load(LS_DEL, [])); // seed events deleted locally (no token to commit yet)
      // Seed events the user deleted locally are hidden from the list; user events are removed outright.
      const allEvents = () => [...seed.filter((e) => !deleted.has(evId(e))), ...userEv].sort((a, b) => a.date.localeCompare(b.date));

      // Commit events.json back to the repo via the GitHub Contents API. The owner supplies a
      // fine-grained token (Contents: read/write, this repo only) stored ONLY in this browser —
      // never in the code. Absent token → local-only. GitHub Pages redeploys → live for everyone.
      const GH = { owner: 'mcorbett51090', repo: 'chateaudelesigny', branch: 'main', path: 'reports/analytics/events.json' };
      const hasToken = () => !!localStorage.getItem(LS_TOK);
      const b64enc = (s) => btoa(unescape(encodeURIComponent(s)));
      const b64dec = (s) => decodeURIComponent(escape(atob(s.replace(/\s/g, ''))));
      const setStatus = (msg, ok) => { const el = $('db-ev-status'); if (el) { el.textContent = msg; el.style.color = ok === false ? 'var(--sang)' : ok ? '#2e7d52' : ''; } };
      async function ghCommit(mutate, message) {
        const token = localStorage.getItem(LS_TOK);
        if (!token) return { ok: false, reason: 'no-token' };
        const base = `https://api.github.com/repos/${GH.owner}/${GH.repo}/contents/${GH.path}`;
        const h = { Authorization: `Bearer ${token}`, Accept: 'application/vnd.github+json', 'X-GitHub-Api-Version': '2022-11-28' };
        try {
          const g = await fetch(`${base}?ref=${GH.branch}`, { headers: h });
          if (!g.ok) return { ok: false, reason: 'read ' + g.status };
          const cur = await g.json();
          let list; try { list = JSON.parse(b64dec(cur.content)); } catch { list = []; }
          const next = mutate(list).sort((a, b) => a.date.localeCompare(b.date));
          const body = { message, content: b64enc(JSON.stringify(next, null, 2) + '\n'), sha: cur.sha, branch: GH.branch };
          const p = await fetch(base, { method: 'PUT', headers: h, body: JSON.stringify(body) });
          return { ok: p.ok, reason: p.ok ? '' : 'write ' + p.status };
        } catch { return { ok: false, reason: 'network' }; }
      }

      const mLabel = (m) => m.slice(5) + '/' + m.slice(2, 4);
      const mNum = (d) => { const [y, mo] = d.split('-').map(Number); return y * 12 + (mo - 1); };
      const activeKeys = () => order.filter((k) => selected.has(k));

      function draw(data, keys, evts) {
        const W = 760, H = 264, pl = 12, pr = 12, pt = 34, pb = 26;
        const n = data.length;
        const X = (i) => pl + (n <= 1 ? (W - pl - pr) / 2 : (i * (W - pl - pr)) / (n - 1));
        const single = keys.length === 1;
        const fillOp = single ? 0.22 : 0.13;
        const step = Math.max(1, Math.ceil(n / 6));
        let xlabels = '';
        for (let i = 0; i < n; i += step) xlabels += `<text x="${X(i).toFixed(1)}" y="${H - 8}" text-anchor="middle" fill="#8a7d6d" font-size="11">${mLabel(data[i].month)}</text>`;
        let areas = '', lines = '', dots = '', vlabels = '';
        keys.forEach((key) => {
          const color = COLORS[key] || '#7a2e2e';
          const vals = data.map(fnMap[key]);
          const max = Math.max(1, ...vals);
          const Y = (v) => pt + (1 - v / max) * (H - pt - pb);
          const pts = vals.map((v, i) => `${X(i).toFixed(1)},${Y(v).toFixed(1)}`).join(' ');
          // translucent area fill in the SAME colour as the line (presentation attrs = universal support)
          areas += `<polygon points="${X(0).toFixed(1)},${H - pb} ${pts} ${X(n - 1).toFixed(1)},${H - pb}" fill="${color}" fill-opacity="${fillOp}" stroke="none"></polygon>`;
          lines += `<polyline points="${pts}" fill="none" stroke="${color}" stroke-width="2" vector-effect="non-scaling-stroke"></polyline>`;
          for (let i = 0; i < n; i++) dots += `<circle cx="${X(i).toFixed(1)}" cy="${Y(vals[i]).toFixed(1)}" r="${i === n - 1 ? 4 : 3}" fill="${color}" stroke="#f6f1e7" stroke-width="1.1"><title>${esc(label[key])} — ${data[i].month}: ${nf.format(vals[i])}</title></circle>`;
          if (single) vlabels += `<text x="${X(n - 1).toFixed(1)}" y="${(Y(vals[n - 1]) - 9).toFixed(1)}" text-anchor="end" fill="${color}" font-size="13" font-weight="600">${nf.format(vals[n - 1])}</text>`;
        });
        // event annotation lines (toggled-on events within the visible date range)
        let evLines = '', evLabels = '';
        if (n >= 1) {
          const s0 = mNum(data[0].month), s1 = mNum(data[n - 1].month);
          const inRange = evts.filter((e) => { const m = mNum(e.date); return m >= s0 && m <= s1; });
          inRange.forEach((e, k) => {
            const m = mNum(e.date);
            const x = s1 === s0 ? pl + (W - pl - pr) / 2 : pl + ((m - s0) / (s1 - s0)) * (W - pl - pr);
            const ly = 10 + (k % 2) * 12;
            const anchor = x < 70 ? 'start' : x > W - 70 ? 'end' : 'middle';
            const short = e.label.length > 20 ? e.label.slice(0, 19) + '…' : e.label;
            evLines += `<line x1="${x.toFixed(1)}" y1="${pt - 4}" x2="${x.toFixed(1)}" y2="${H - pb}" stroke="#8a7d6d" stroke-width="1" stroke-dasharray="3 3" opacity="0.6"></line>`;
            evLabels += `<text x="${x.toFixed(1)}" y="${ly}" text-anchor="${anchor}" fill="#5a5048" font-size="10">${esc(short)}<title>${esc(e.date + ' — ' + e.label)}</title></text>`;
          });
        }
        return `<svg viewBox="0 0 ${W} ${H}" style="width:100%;height:auto;display:block" preserveAspectRatio="xMidYMid meet">${areas}${lines}${dots}${evLines}${evLabels}${vlabels}${xlabels}</svg>`;
      }

      function renderEventList() {
        const list = $('db-ev-list');
        list.innerHTML = allEvents().map((e) => {
          const id = evId(e), on = !off.has(id);
          return `<li class="db__ev">
            <label><input type="checkbox" data-id="${esc(id)}" ${on ? 'checked' : ''}>
            <span class="db__ev-d">${esc(e.date)}</span>
            <span class="db__ev-t" title="${esc(e.label)}">${esc(e.label)}</span></label>
            <button type="button" class="db__ev-x" data-del="${esc(id)}" aria-label="${isFr ? 'Supprimer' : 'Remove'}">×</button>
          </li>`;
        }).join('') || `<li class="db__ev-empty slate">${isFr ? 'Aucun événement.' : 'No events.'}</li>`;
        list.querySelectorAll('input[type=checkbox]').forEach((c) =>
          c.addEventListener('change', () => { const id = c.dataset.id; if (c.checked) off.delete(id); else off.add(id); save(LS_OFF, [...off]); render(); })
        );
        list.querySelectorAll('[data-del]').forEach((b) =>
          b.addEventListener('click', async () => {
            const id = b.dataset.del;
            const wasUser = userEv.some((e) => evId(e) === id);
            if (wasUser) {
              userEv = userEv.filter((e) => evId(e) !== id);
              save(LS_ADD, userEv.map(({ user, ...r }) => r));
            } else {
              deleted.add(id); save(LS_DEL, [...deleted]); // seed event: delete it locally (persisted)
            }
            off.delete(id); save(LS_OFF, [...off]);
            renderEventList(); render();
            if (hasToken()) {
              setStatus(isFr ? 'Suppression…' : 'Removing…');
              const r = await ghCommit((l) => l.filter((e) => evId(e) !== id), 'Remove analytics event: ' + id.replace('|', ' '));
              if (r.ok) { deleted.delete(id); save(LS_DEL, [...deleted]); } // now removed from the file itself
              setStatus(r.ok ? (isFr ? 'Supprimé du site ✓' : 'Removed from the site ✓') : (isFr ? 'Échec de la suppression (' + r.reason + ')' : 'Remove failed (' + r.reason + ')'), r.ok);
            } else if (!wasUser) {
              setStatus(isFr ? 'Supprimé (ce navigateur uniquement).' : 'Deleted (this browser only).');
            }
          })
        );
      }

      function render() {
        const keys = activeKeys();
        const data = tf ? series.slice(-tf) : series;
        const onEv = allEvents().filter((e) => !off.has(evId(e)));
        chart.innerHTML = keys.length ? draw(data, keys, onEv) : '';
        chips.forEach((b) => { const k = b.dataset.metric; const tot = data.reduce((a, s) => a + fnMap[k](s), 0); const lv = b.querySelector('.db__lv'); if (lv) lv.textContent = nf.format(tot); });
        const months = data.length, per = isFr ? `sur ${months} mois` : `over ${months} months`;
        if (keys.length === 1) {
          const f = fnMap[keys[0]];
          const total = data.reduce((a, s) => a + f(s), 0);
          const prev = tf ? series.slice(-2 * tf, -tf) : [];
          const ptot = prev.reduce((a, s) => a + f(s), 0);
          const pct = ptot ? Math.round(((total - ptot) / ptot) * 100) : null;
          let d = '';
          if (pct !== null) { const ar = pct >= 0 ? '▲' : '▼'; d = ` · <span class="${pct >= 0 ? 'up' : 'down'}">${ar} ${Math.abs(pct)}% ${isFr ? 'vs période précédente' : 'vs previous period'}</span>`; }
          sumEl.innerHTML = `<strong>${nf.format(total)}</strong> ${label[keys[0]].toLowerCase()} ${per}${d}`;
        } else if (keys.length > 1) {
          sumEl.innerHTML = isFr ? `<strong>${keys.length} mesures</strong> comparées ${per} · échelles indépendantes` : `<strong>${keys.length} metrics</strong> compared ${per} · independent scales`;
        } else sumEl.innerHTML = isFr ? 'Choisissez au moins une mesure.' : 'Select at least one metric.';
      }

      chips.forEach((b) => b.addEventListener('click', () => {
        const k = b.dataset.metric;
        if (selected.has(k)) { if (selected.size === 1) return; selected.delete(k); } else selected.add(k);
        const on = selected.has(k); b.classList.toggle('is-on', on); b.setAttribute('aria-pressed', on ? 'true' : 'false'); render();
      }));
      trend.querySelectorAll('[data-role="tf"] button').forEach((b) => b.addEventListener('click', () => {
        tf = parseInt(b.getAttribute('data-tf'), 10);
        b.parentElement.querySelectorAll('button').forEach((x) => x.classList.toggle('is-on', x === b)); render();
      }));
      $('db-ev-add').addEventListener('submit', async (e) => {
        e.preventDefault();
        const date = $('db-ev-date').value, lab = $('db-ev-label').value.trim();
        if (!date || !lab) return;
        const nv = { date, label: lab };
        if (allEvents().some((x) => evId(x) === evId(nv))) { setStatus(isFr ? 'Cet événement existe déjà.' : 'That event already exists.', false); return; }
        userEv.push({ ...nv, user: true });
        save(LS_ADD, userEv.map(({ user, ...r }) => r));
        $('db-ev-label').value = ''; $('db-ev-date').value = '';
        renderEventList(); render();
        if (hasToken()) {
          setStatus(isFr ? 'Enregistrement sur le site…' : 'Saving to the site…');
          const r = await ghCommit((l) => (l.some((x) => evId(x) === evId(nv)) ? l : [...l, nv]), `Add analytics event: ${nv.date} ${nv.label}`);
          setStatus(
            r.ok
              ? (isFr ? 'Enregistré sur le site ✓ — visible par tous dans ~1 min.' : 'Saved to the site ✓ — live for everyone in ~1 min.')
              : (isFr ? 'Ajouté ici seulement — échec de l’enregistrement (' + r.reason + ').' : 'Added locally only — save failed (' + r.reason + ').'),
            r.ok
          );
        } else {
          setStatus(isFr ? 'Ajouté (ce navigateur uniquement). Activez « Enregistrer sur le site » pour le partager.' : 'Added (this browser only). Enable “Save to the site” to share it.');
        }
      });
      $('db-ev-all').addEventListener('click', () => {
        const ids = allEvents().map(evId);
        if (off.size >= ids.length) off = new Set(); else off = new Set(ids);
        save(LS_OFF, [...off]); renderEventList(); render();
      });

      // Token save / clear (stored raw, only in this browser).
      function updateSyncUI() {
        const s = document.querySelector('.db__ev-sync summary');
        if (s) s.textContent = hasToken() ? (isFr ? '⚙ Enregistrement activé ✓' : '⚙ Saving enabled ✓') : (isFr ? '⚙ Enregistrer sur le site' : '⚙ Save to the site');
      }
      $('db-gh-save').addEventListener('click', () => {
        const v = $('db-gh-token').value.trim();
        if (v) { localStorage.setItem(LS_TOK, v); $('db-gh-token').value = ''; setStatus(isFr ? 'Jeton enregistré dans ce navigateur ✓' : 'Token saved in this browser ✓', true); }
        else { localStorage.removeItem(LS_TOK); setStatus(isFr ? 'Jeton effacé.' : 'Token cleared.'); }
        updateSyncUI(); renderEventList();
      });

      updateSyncUI();
      renderEventList();
      render();
    })();
  </script>
</PageLayout>

