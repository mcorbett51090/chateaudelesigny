---
import { getImage } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import Photo from '../../components/Photo.astro';
import Lightbox from '../../components/Lightbox.astro';
import { site } from '../../config/site';
import { locales, type Locale, useT, localeBase } from '../../i18n/ui';
import { photos } from '../../assets/images';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useT(locale);
const base = localeBase(locale);
const isFr = locale === 'fr';

const priceFr =
  new Intl.NumberFormat('fr-FR').format(site.weddings.priceFromEUR) + ' €';
const priceEn = '€' + new Intl.NumberFormat('en-GB').format(site.weddings.priceFromEUR);
const priceStr = isFr ? priceFr : priceEn;

const eventTypes = [
  {
    n: '01',
    fr: 'Mariage',
    en: 'Wedding',
    frDesc: 'Cérémonie civile ou religieuse, cocktail et dîner de gala dans les intérieurs Renaissance.',
    enDesc: 'Civil or religious ceremony, cocktail reception and gala dinner within Renaissance interiors.',
  },
  {
    n: '02',
    fr: 'Anniversaire',
    en: 'Birthday',
    frDesc: 'Célébrations privées dans un écrin sans pareil, de l\'intime au grand rassemblement.',
    enDesc: 'Private celebrations in an unrivalled setting, from intimate gatherings to grand parties.',
  },
  {
    n: '03',
    fr: 'Conférence',
    en: 'Conference',
    frDesc: 'Salles modulables et équipements audiovisuels disponibles sur demande.',
    enDesc: 'Flexible rooms with audiovisual equipment available on request.',
  },
  {
    n: '04',
    fr: 'Séminaire d\'entreprise',
    en: 'Corporate',
    frDesc: 'Team building, séminaires résidentiels et dîners de gala dans un cadre mémorable.',
    enDesc: 'Team building, residential seminars and gala dinners in a memorable setting.',
  },
  {
    n: '05',
    fr: 'Showroom',
    en: 'Showroom',
    frDesc: 'Lancement de produit ou présentation de marque dans les intérieurs du XVIe siècle.',
    enDesc: 'Product launches and brand presentations within 16th-century interiors.',
  },
  {
    n: '06',
    fr: 'Baptême',
    en: 'Baptism',
    frDesc: 'Célébrations intimes pour accueillir un nouveau membre au sein de la famille.',
    enDesc: 'Intimate gatherings to welcome a new family member in style.',
  },
  {
    n: '07',
    fr: 'Bar & Bat Mitsvah',
    en: 'Bar & Bat Mitzvah',
    frDesc: 'Réceptions de tradition dans un cadre d\'exception à moins de 30 minutes de Paris.',
    enDesc: 'Traditional celebrations in an exceptional setting less than 30 minutes from Paris.',
  },
];

const partners = [
  {
    fr: 'Traiteur',
    en: 'Catering',
    frDesc: 'Gastronomie sur mesure et cocktails d\'exception.',
    enDesc: 'Bespoke gastronomy and exceptional cocktail receptions.',
    photo: 'catering-canapes',
    frAlt: 'Canapés gastronomiques pour cocktail de mariage',
    enAlt: 'Gourmet canapés for wedding cocktail reception',
  },
  {
    fr: 'Photographie',
    en: 'Photography',
    frDesc: 'Photographes sélectionnés pour leur sensibilité au lieu.',
    enDesc: 'Photographers chosen for their feel for the estate.',
    photo: 'makeup-artist',
    frAlt: 'Artiste maquillage lors des préparatifs du mariage',
    enAlt: 'Makeup artist during wedding preparations',
  },
  {
    fr: 'Décoration',
    en: 'Decoration',
    frDesc: 'Scénographie florale et mise en scène artistique.',
    enDesc: 'Floral and artistic event staging.',
    photo: 'int-painted-ceiling',
    frAlt: 'Plafond peint des intérieurs du château',
    enAlt: 'Painted ceiling of the château interiors',
  },
  {
    fr: 'Animation',
    en: 'Entertainment',
    frDesc: 'Musiciens, groupes, DJ et prestations artistiques.',
    enDesc: 'Musicians, bands, DJs and live performances.',
    photo: 'music-sax',
    frAlt: 'Saxophoniste lors d\'une réception de mariage',
    enAlt: 'Saxophonist at a wedding reception',
  },
  {
    fr: 'Organisation',
    en: 'Planning',
    frDesc: 'Wedding planners agréés pour un accompagnement complet.',
    enDesc: 'Approved wedding planners for end-to-end coordination.',
    photo: 'couple-bouquet',
    frAlt: 'Bouquet de la mariée lors de la réception',
    enAlt: 'Bridal bouquet at the reception',
  },
];

const galleryPlates = [
  {
    fr: 'La Salle des Tapisseries',
    en: 'The Tapestry Hall',
    frSub: 'Grande salle Renaissance',
    enSub: 'Grand Renaissance Hall',
    photo: 'int-grand-hall',
    frAlt: 'Grande salle du château dressée pour un dîner de gala',
    enAlt: 'Grand hall of the château set for a gala dinner',
  },
  {
    fr: 'Le Salon d\'Honneur',
    en: 'The Honour Salon',
    frSub: 'Parquet & cheminées sculptées',
    enSub: 'Parquet & carved stone mantels',
    photo: 'int-reception-set',
    frAlt: 'Salon d\'Honneur dressé pour une réception',
    enAlt: 'Honour Salon set for a reception',
  },
  {
    fr: 'La Salle de Bal',
    en: 'The Ballroom',
    frSub: 'Tentures écarlates & parquet',
    enSub: 'Scarlet drapes & parquet',
    photo: 'int-ballroom-red',
    frAlt: 'Salle de bal aux tentures écarlates',
    enAlt: 'Ballroom draped in scarlet',
  },
  {
    fr: 'Le Salon aux Cheminées',
    en: 'The Fireplace Salon',
    frSub: 'Cheminée sculptée & parquet d\'époque',
    enSub: 'Carved stone mantel & period parquet',
    photo: 'int-fireplace-parquet',
    frAlt: 'Cheminée de pierre sculptée et parquet d\'époque',
    enAlt: 'Carved stone fireplace and period parquet',
  },
  {
    fr: 'Les Préparatifs',
    en: 'The Getting-Ready Suite',
    frSub: 'Grandes baies — lumière du matin',
    enSub: 'Tall windows — morning light',
    photo: 'int-window-drapes',
    frAlt: 'Fenêtres drapées des intérieurs Renaissance',
    enAlt: 'Draped windows of the Renaissance interiors',
  },
];

// Lightbox targets: full-size (1600w) render + intrinsic dimensions for each
// gallery plate's photo. Plates with no matching asset render the plain
// (non-linked) <Photo> below — PhotoSwipe needs real dimensions.
type LightboxTarget = { src: string; w: number; h: number };
const galleryLightbox: (LightboxTarget | null)[] = await Promise.all(
  galleryPlates.map(async (plate) => {
    const meta = photos[plate.photo];
    if (!meta) return null;
    const big = await getImage({ src: meta, width: 1600, format: 'webp' });
    const h = Math.round(1600 * meta.height / meta.width);
    return { src: big.src, w: 1600, h };
  })
);
---

<PageLayout
  title={isFr
    ? 'Mariages & Événements · Château de Lésigny'
    : 'Weddings & Events · Château de Lésigny'}
  description={isFr
    ? 'Organisez votre mariage au Château de Lésigny — intérieurs Renaissance, jusqu\'à 350 invités, à 24 km de Paris. À partir de 3 350 €.'
    : 'Plan your wedding at Château de Lésigny — Renaissance interiors, up to 350 guests, 24 km from Paris. From €3,350.'}
  locale={locale}
  path="mariages/"
>

  <!-- ① Hero ---------------------------------------------------------------- -->
  <section class="m-hero is-dark" aria-labelledby="m-hero-title">
    <Photo
      fill
      name="exterior-ceremony-lawn"
      alt={isFr ? 'Cérémonie en plein air sur la pelouse du Château de Lésigny' : 'Outdoor ceremony on the lawn at Château de Lésigny'}
      loading="eager"
    />
    <div class="m-hero__scrim" aria-hidden="true"></div>
    <div class="wrap-wide m-hero__inner">
      <p class="eyebrow m-hero__eyebrow" data-reveal>
        {isFr
          ? `Mariages & Événements · depuis ${site.founded}`
          : `Weddings & Events · since ${site.founded}`}
      </p>
      <h1 id="m-hero-title" class="m-hero__title" data-reveal>
        {isFr
          ? 'Créez le souvenir d\'une vie.'
          : 'Create the memory of a lifetime.'}
      </h1>
      <p class="m-hero__lede" data-reveal>
        {isFr
          ? `À ${site.address.fromParisKm} km de Paris, le Château de Lésigny offre un cadre Renaissance unique pour votre mariage et vos réceptions privées — jusqu’à ${site.weddings.capacityCeremony} invités, dans 300 m² de salles communicantes sur ${site.estate.acres} acres de parc.`
          : `${site.address.fromParisKm} km from Paris, Château de Lésigny provides a singular Renaissance setting for your wedding and private events — up to ${site.weddings.capacityCeremony} guests across 300 m² of communicating rooms within ${site.estate.acres} acres of parkland.`}
      </p>
      <div class="m-hero__actions" data-reveal>
        <a class="btn btn--primary" href={`${base}/contact/?stream=wedding`}>
          {isFr ? 'Demander une date' : 'Request a date'}
        </a>
        <a class="btn btn--ghost" href="#le-chateau">
          {isFr ? 'Découvrir le lieu' : 'Explore the venue'}
        </a>
      </div>
    </div>
    <div class="wrap-wide m-hero__rule-wrap"><hr class="rule" /></div>
  </section>

  <!-- ② Capacities band ----------------------------------------------------- -->
  <section
    class="m-caps is-dark"
    aria-label={isFr ? 'Capacités d\'accueil' : 'Venue capacity'}
  >
    <div class="wrap-wide m-caps__grid">
      <div class="m-cap" data-reveal>
        <span class="m-cap__n" aria-label={String(site.weddings.capacityCocktail)}>
          {site.weddings.capacityCocktail}
        </span>
        <span class="m-cap__l slate">
          {isFr ? 'cocktail' : 'cocktail'}
        </span>
      </div>
      <div class="m-cap" data-reveal>
        <span class="m-cap__n" aria-label={String(site.weddings.capacityDinner)}>
          {site.weddings.capacityDinner}
        </span>
        <span class="m-cap__l slate">
          {isFr ? 'dîner assis' : 'seated dinner'}
        </span>
      </div>
      <div class="m-cap" data-reveal>
        <span class="m-cap__n" aria-label={String(site.weddings.capacityCeremony)}>
          {site.weddings.capacityCeremony}
        </span>
        <span class="m-cap__l slate">
          {isFr ? 'cérémonie' : 'ceremony'}
        </span>
      </div>
    </div>
  </section>

  <!-- ③ Le Château ---------------------------------------------------------- -->
  <section class="section m-chateau" id="le-chateau" aria-labelledby="m-chateau-title">
    <div class="wrap-wide">

      <div class="m-chateau__intro" data-reveal>
        <div class="m-chateau__copy flow">
          <p class="eyebrow">{isFr ? 'Le Château' : 'The Château'}</p>
          <h2 id="m-chateau-title">
            {isFr
              ? 'Intérieurs Renaissance, dehors comme dedans.'
              : 'Renaissance interiors, inside and out.'}
          </h2>
          <p>
            {isFr
              ? `Construit en ${site.founded}, le Château de Lésigny conserve ses plafonds à caissons, ses cheminées de pierre sculptée, ses parquets d’époque et son grand escalier de marbre. Chaque salle est un décor en soi — un cadre que nul architecte contemporain ne saurait recréer.`
              : `Built in ${site.founded}, Château de Lésigny retains its coffered ceilings, carved stone mantels, period parquet floors and grand marble staircase. Every room is a setting in its own right — a backdrop no contemporary architect could recreate.`}
          </p>
          <p>
            {isFr
              ? `Avec 300 m² de salles communicantes sur ${site.estate.acres} acres de parc, le domaine offre une souplesse rare : cérémonie au cœur des intérieurs, cocktail en terrasse, dîner dans la grande salle.`
              : `With 300 m² of communicating rooms across ${site.estate.acres} acres of parkland, the estate offers rare flexibility: ceremony within the interiors, cocktail on the terrace, dinner in the grand hall.`}
          </p>
          <p class="m-price">
            <span class="m-price__label slate">
              {isFr ? 'Location à partir de' : 'Venue hire from'}
            </span>
            <span class="m-price__value">{priceStr}</span>
          </p>
        </div>
      </div>

      <!-- Gallery — swappable image slots: replace .m-plate background-color with an <img> or background-image when photography is available -->
      <div
        class="m-gallery"
        aria-label={isFr ? 'Aperçu des espaces' : 'Venue spaces overview'}
        data-reveal
        data-pswp-gallery
      >
        {galleryPlates.map((plate, i) => {
          const lb = galleryLightbox[i];
          return (
            <div class={`m-plate m-plate--${i + 1}`}>
              {lb ? (
                <a
                  class="pswp-item"
                  href={lb.src}
                  data-pswp-width={lb.w}
                  data-pswp-height={lb.h}
                  target="_blank"
                  rel="noopener"
                  aria-label={isFr
                    ? `Agrandir : ${plate.fr}`
                    : `Enlarge: ${plate.en}`}
                >
                  <Photo fill name={plate.photo} alt={isFr ? plate.frAlt : plate.enAlt} />
                </a>
              ) : (
                <Photo fill name={plate.photo} alt={isFr ? plate.frAlt : plate.enAlt} />
              )}
              <div class="m-plate__inner">
                <p class="m-plate__name">{isFr ? plate.fr : plate.en}</p>
                <p class="m-plate__sub slate">{isFr ? plate.frSub : plate.enSub}</p>
              </div>
            </div>
          );
        })}
      </div>

    </div>
  </section>

  <!-- ④ Event types --------------------------------------------------------- -->
  <section class="section m-events" aria-labelledby="m-events-title">
    <div class="wrap-wide">
      <div class="m-events__header" data-reveal>
        <p class="eyebrow">{isFr ? 'Événements' : 'Events'}</p>
        <h2 id="m-events-title">
          {isFr
            ? 'Un lieu pour chaque célébration.'
            : 'A setting for every celebration.'}
        </h2>
      </div>
      <ul class="m-events__grid" role="list">
        {eventTypes.map((ev) => (
          <li class="m-event" data-reveal>
            <span class="m-event__n slate" aria-hidden="true">{ev.n}</span>
            <h3 class="m-event__title">{isFr ? ev.fr : ev.en}</h3>
            <p class="m-event__desc">{isFr ? ev.frDesc : ev.enDesc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ⑤ Partners ------------------------------------------------------------ -->
  <section class="m-partners is-dark" aria-labelledby="m-partners-title">
    <div class="wrap-wide">
      <div class="m-partners__header" data-reveal>
        <p class="eyebrow">{isFr ? 'Prestataires' : 'Partners'}</p>
        <h2 id="m-partners-title">
          {isFr
            ? 'Un réseau de partenaires triés sur le volet.'
            : 'A curated network of trusted partners.'}
        </h2>
      </div>
      <ul class="m-partners__list" role="list">
        {partners.map((p) => (
          <li class="m-partner" data-reveal>
            <Photo name={p.photo} alt={isFr ? p.frAlt : p.enAlt} ratio="4/3" class="m-partner__photo" />
            <div class="m-partner__body">
              <h3 class="m-partner__title">{isFr ? p.fr : p.en}</h3>
              <p class="m-partner__desc">{isFr ? p.frDesc : p.enDesc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ⑥ Testimonials -------------------------------------------------------- -->
  <section class="section m-testimonials" aria-labelledby="m-testi-label">
    <div class="wrap">
      <p id="m-testi-label" class="eyebrow m-testimonials__eyebrow" data-reveal>
        {isFr ? 'Témoignages' : 'Testimonials'}
      </p>
      <!-- Real, attributed testimonials will live here. The live site has none to
           seed yet, so we point couples to the venue's actual review channels
           rather than ship fabricated quotes. -->
      <p class="m-testi__lead" data-reveal style="max-width:58ch;color:var(--text-muted);line-height:1.7;">
        {isFr
          ? 'Les retours de nos couples vivent sur nos réseaux et nos plateformes partenaires. De véritables témoignages, attribués, seront mis à l’honneur ici prochainement.'
          : 'Our couples’ words live on our social channels and partner platforms. Real, attributed testimonials will be featured here soon.'}
      </p>
      <div class="m-testi__actions" data-reveal style="display:flex;gap:var(--space-s);flex-wrap:wrap;margin-top:var(--space-m);">
        <a class="btn btn--primary" href={site.social.instagram} target="_blank" rel="noopener noreferrer">
          {isFr ? 'Nos mariages sur Instagram' : 'Our weddings on Instagram'}
        </a>
        <a class="btn btn--ghost" href={site.social.mariagesnet} target="_blank" rel="noopener noreferrer">
          {isFr ? 'Avis · Mariages.net' : 'Reviews · Mariages.net'}
        </a>
      </div>
    </div>
  </section>

  <!-- ⑦ Closing CTA band ---------------------------------------------------- -->
  <section class="m-cta is-dark" aria-labelledby="m-cta-title">
    <Photo
      fill
      duotone
      name="exterior-evening"
      alt={isFr ? 'Le Château de Lésigny au crépuscule' : 'Château de Lésigny at dusk'}
    />
    <div class="m-cta__scrim" aria-hidden="true"></div>
    <div class="wrap m-cta__inner" data-reveal>
      <p class="eyebrow">{isFr ? 'Réservez votre date' : 'Reserve your date'}</p>
      <h2 id="m-cta-title" class="m-cta__title">
        {isFr
          ? 'Votre histoire mérite un cadre d\'exception.'
          : 'Your story deserves an exceptional setting.'}
      </h2>
      <p class="m-cta__sub">
        {isFr
          ? 'Notre équipe est à votre disposition pour organiser une visite privée et construire le programme qui vous ressemble.'
          : 'Our team is at your disposal to arrange a private visit and build a programme that suits you perfectly.'}
      </p>
      <div class="m-cta__actions">
        <a class="btn btn--primary" href={`${base}/contact/?stream=wedding`}>
          {isFr ? 'Demander une date' : 'Request a date'}
        </a>
      </div>
      <p class="m-cta__phone-wrap">
        <a
          class="m-cta__phone"
          href={`tel:${site.contact.phoneEvents.replace(/\s/g, '')}`}
          aria-label={isFr
            ? `Appeler le ${site.contact.phoneEvents}`
            : `Call ${site.contact.phoneEvents}`}
        >
          {site.contact.phoneEvents}
        </a>
      </p>
    </div>
  </section>

  <Lightbox />

</PageLayout>

<style>
  /* =========================================================================
     Mariages & Événements — page-scoped styles
     All tokens from tokens.css; no new values introduced.
     ========================================================================= */

  /* --- ① Hero --------------------------------------------------------------- */
  .m-hero {
    position: relative;
    overflow: hidden;
    background: var(--suie);
    padding-block: clamp(4rem, 13vh, 10rem) var(--space-l);
  }

  .m-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      170deg,
      color-mix(in srgb, var(--encre) 58%, transparent) 0%,
      color-mix(in srgb, var(--encre) 48%, transparent) 100%
    );
  }

  .m-hero__inner { display: grid; gap: 0; position: relative; z-index: 2; }

  .m-hero__eyebrow { margin-bottom: var(--space-m); }

  .m-hero__title {
    font-size: var(--step-5);
    max-width: 18ch;
    margin-bottom: var(--space-m);
  }

  .m-hero__lede {
    font-size: var(--step-1);
    color: var(--text-muted);
    max-width: 52ch;
    margin-bottom: var(--space-l);
  }

  .m-hero__actions {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .m-hero__rule-wrap { margin-top: var(--space-2xl); position: relative; z-index: 2; }

  /* --- ② Capacities band --------------------------------------------------- */
  .m-caps {
    background: var(--suie);
    padding-block: var(--space-2xl);
  }

  .m-caps__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
    text-align: center;
    position: relative;
  }

  /* Brass hairline dividers between the three numerals */
  .m-cap + .m-cap {
    border-left: var(--hairline) solid var(--rule);
  }

  .m-cap {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    align-items: center;
    padding-block: var(--space-s);
  }

  .m-cap__n {
    font-family: var(--font-display);
    font-size: var(--step-5);
    font-weight: 420;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ivoire);
    font-variation-settings: 'SOFT' 30, 'WONK' 0, 'opsz' 144;
  }

  .m-cap__l {
    font-size: var(--step--1);
    color: var(--laiton-soft);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* --- ③ Le Château -------------------------------------------------------- */
  .m-chateau__intro {
    display: grid;
    grid-template-columns: 1fr;
    max-width: var(--measure);
  }

  .m-chateau__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .m-chateau__copy h2 {
    margin-top: var(--space-3xs);
  }

  .m-price {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    margin-top: var(--space-m);
    padding-top: var(--space-m);
    border-top: var(--hairline) solid var(--rule);
  }

  .m-price__label {
    font-size: var(--step--1);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .m-price__value {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 420;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1;
  }

  /* Gallery — 6-column grid: 3 portrait plates (span 2) + 2 landscape (span 3) */
  .m-gallery {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-m);
    margin-top: var(--space-2xl);
  }

  .m-plate {
    position: relative;
    background: var(--suie);
    box-shadow: inset 0 0 0 1px var(--laiton);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-m);
    overflow: hidden;
    transition: box-shadow var(--dur-mid) var(--ease-soft);
  }

  /* Bottom-to-top gradient scrim — ensures caption legibility over any photo */
  .m-plate::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--encre) 75%, transparent) 0%,
      color-mix(in srgb, var(--encre) 20%, transparent) 45%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* Lightbox click target — fills the plate exactly like the fill Photo it
     wraps did before (no explicit z-index, so it stays at the same paint
     level as the photo: below the ::after scrim and the caption). */
  .m-plate .pswp-item {
    position: absolute;
    inset: 0;
    display: block;
  }
  .m-plate .pswp-item:focus-visible {
    outline: 2px solid var(--laiton-soft);
    outline-offset: -2px;
    z-index: 3;
  }

  /* Row 1: three equal portrait plates */
  .m-plate--1,
  .m-plate--2,
  .m-plate--3 {
    grid-column: span 2;
    aspect-ratio: 4 / 5;
  }

  /* Row 2: two wider landscape plates */
  .m-plate--4,
