<script>
  // Toggle: progressive enhancement.
  // Without JS both panels are readable (stacked).
  // With JS, panels become mutually exclusive; buttons are fully keyboard-operable.
  (function () {
    const containers = document.querySelectorAll<HTMLElement>('[data-photo-toggle]');
    containers.forEach((container) => {
      const btns = Array.from(container.querySelectorAll<HTMLButtonElement>('[data-target]'));
      const panels = Array.from(container.querySelectorAll<HTMLElement>('[data-panel]'));
      if (!btns.length || !panels.length) return;

      // Signal JS is active — collapses no-JS second-panel margin
      container.classList.add('is-js');

      // Determine initial active target from aria-pressed="true"
      const initialBtn = btns.find((b) => b.getAttribute('aria-pressed') === 'true') ?? btns[0];
      const activeTarget = initialBtn.dataset.target!;

      // Hide all inactive panels
      panels.forEach((p) => {
        if (p.dataset.panel !== activeTarget) p.hidden = true;
      });

      function activate(target: string) {
        btns.forEach((b) =>
          b.setAttribute('aria-pressed', String(b.dataset.target === target))
        );
        panels.forEach((p) => {
          p.hidden = p.dataset.panel !== target;
        });
      }

      btns.forEach((btn) => {
        btn.addEventListener('click', () => activate(btn.dataset.target!));
      });
    });
  })();
</script>

<script>
  // Décor popup dialogs — progressive enhancement.
  // Without JS: plates show their descriptions inline; dialogs stay closed.
  // With JS: each plate’s "Voir / View" button opens a native <dialog> as a modal.
  (function () {
    const triggers = document.querySelectorAll<HTMLButtonElement>('[aria-haspopup="dialog"]');

    triggers.forEach((trigger) => {
      const dialogId = trigger.getAttribute('aria-controls');
      if (!dialogId) return;
      const dialog = document.getElementById(dialogId) as HTMLDialogElement | null;
      if (!(dialog instanceof HTMLDialogElement)) return;

      const closeBtn = dialog.querySelector<HTMLButtonElement>('.ph-dialog__close');

      // Open
      trigger.addEventListener('click', () => {
        dialog.showModal();
        // Move focus into the dialog — prefer the close button
        const firstFocusable =
          closeBtn ?? dialog.querySelector<HTMLElement>('button, a[href], [tabindex]');
        firstFocusable?.focus();
      });

      // Close via close button
      closeBtn?.addEventListener('click', () => dialog.close());

      // Close via backdrop click (pointer lands on <dialog> element, not inner content)
      dialog.addEventListener('click', (e: MouseEvent) => {
        if (e.target === dialog) dialog.close();
      });

      // Restore focus on close (handles close button, Escape key, and backdrop)
      dialog.addEventListener('close', () => trigger.focus());
    });
  })();
</script>
