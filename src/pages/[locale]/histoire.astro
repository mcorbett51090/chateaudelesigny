---
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import Photo from '../../components/Photo.astro';
import portraitGaligai from '../../assets/history/leonora-galigai.jpg';
import portraitMarie from '../../assets/history/marie-de-medicis.jpg';
import portraitLouis from '../../assets/history/louis-xiii.jpg';
import portraitCatherine from '../../assets/history/catherine-de-medicis.jpg';
import portraitConcini from '../../assets/history/concino-concini.jpg';
import carteHero from '../../assets/history/carte-isle-de-france-1746.jpg';
import { site } from '../../config/site';
import CompareSlider from '../../components/CompareSlider.astro';
import { features } from '../../config/features';
import { locales, type Locale, useT, localeBase } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useT(locale);
const base = localeBase(locale);
const isFr = locale === 'fr';

const yearsOld = 2026 - site.founded;

// Chronology grounded in primary/heritage sources (montjoye.net, ABC Salles,
// fr.wikipedia, local histories). Well-documented beats only; uncertain or
// single-source specifics are kept general or flagged /* VERIFY */.
const timelineEntries = [
  {
    year: '1508',
    fr: 'La famille de Poncher, proche du pouvoir royal sous François Iᵉʳ, acquiert la terre de Lésigny et y élève un premier château, délaissant l’ancienne demeure médiévale. L’église du village est bâtie dans la foulée.',
    en: 'The Poncher family, close to royal power under Francis I, acquires the Lésigny estate and raises a first château, leaving the old medieval dwelling behind. The village church follows soon after.',
  },
  {
    year: 'v. 1550',
    fr: 'Charles de Pierrevive et Charlotte Briçonnet font reconstruire la demeure dans le goût de la Renaissance : c’est, pour l’essentiel, le château que vous découvrez aujourd’hui. En 1573, Catherine de Médicis y séjourne quelques jours.',
    en: 'Charles de Pierrevive and Charlotte Briçonnet rebuild the residence in the Renaissance taste — in essence the château you see today. In 1573, Catherine de’ Medici stays here for several days.',
    portrait: portraitCatherine,
    cap: 'Catherine de Médicis',
  },
  {
    year: '1613',
    fr: 'Léonora Dori, dite « la Galigaï » — épouse de Concini, futur maréchal d’Ancre, et confidente de Marie de Médicis — achète Lésigny pour 95 000 livres. Elle y mène de grands travaux : orangerie, jardins et une chapelle consacrée en 1615. La reine mère s’y rend la même année.',
    en: 'Léonora Dori, known as “la Galigaï” — wife of Concini, the future Maréchal d’Ancre, and confidante of Marie de’ Medici — buys Lésigny for 95,000 livres. She undertakes major works: an orangery, gardens, and a chapel consecrated in 1615. The Queen Mother visits that same year.',
    portrait: portraitGaligai,
    cap: 'Léonora Galigaï',
  },
  {
    year: '1617',
    fr: 'La disgrâce est brutale : Concini est assassiné au Louvre, la Galigaï exécutée. Le domaine échoit à Charles d’Albert de Luynes, favori de Louis XIII. Le roi et Anne d’Autriche y séjournent en 1618 ; Marie de Rohan s’y marie dans la chapelle du château.',
    en: 'The fall is brutal: Concini is assassinated at the Louvre and la Galigaï executed. The estate passes to Charles d’Albert de Luynes, favourite of Louis XIII. The king and Anne of Austria lodge here in 1618; Marie de Rohan is married in the château’s chapel.',
    portrait: portraitLouis,
    cap: 'Louis XIII',
  },
  {
    year: 'XVIIIᵉ s.',
    fr: 'Après les familles de Boislevé et d’Armaillé, Lésigny entre dans le patrimoine de la maison de Bourbon-Penthièvre, descendance légitimée de Louis XIV. Le pont de bois cède alors la place à un pont de pierre.',
    en: 'After the Boislevé and d’Armaillé families, Lésigny enters the holdings of the House of Bourbon-Penthièvre, a legitimised line of Louis XIV. The wooden bridge gives way to one of stone.',
  },
  {
    year: '1794',
    fr: 'La Révolution frappe le domaine du duc de Penthièvre : les quatre tours d’angle du château sont abattues sur ordre du district et les pièces d’eau asséchées. Le château perd alors sa silhouette défensive.',
    en: 'The Revolution strikes the Duke of Penthièvre’s estate: the château’s four corner towers are pulled down by order of the district and the ponds drained. The château loses its defensive silhouette.',
  },
  {
    year: 'XIXᵉ s.',
    fr: 'Sous une succession de propriétaires — le vicomte de la Brosse, l’agent de change Archdéacon, puis la famille de Pérignon — le château est restauré et ses intérieurs reconfigurés, tout en préservant l’ossature Renaissance.',
    en: 'Under a succession of owners — the Vicomte de la Brosse, the stockbroker Archdéacon, then the Pérignon family — the château is restored and its interiors reworked, while the Renaissance bones are preserved.',
  },
  {
    year: 'XXᵉ s.',
    fr: 'Le château connaît de nouvelles vies — dont, à partir de 1958, celle de Jacques Lacroix, cofondateur du Studio Harcourt, qui le restaure. Ses décors authentiques attirent peu à peu les productions de cinéma et de télévision.',
    /* VERIFY: Jacques Lacroix / Studio Harcourt 1958–1973 — single heritage source (montjoye.net) */
    en: 'The château lives several new lives — including, from 1958, that of Jacques Lacroix, co-founder of Studio Harcourt, who restores it. Its authentic settings gradually draw film and television productions.',
    /* VERIFY: Jacques Lacroix / Studio Harcourt 1958–1973 — single heritage source (montjoye.net) */
  },
  {
    year: '2020',
    fr: 'Daphne Reckert hérite du château cinq fois centenaire de son grand-père. Avec Ian Figueira, elle entreprend de redonner vie au domaine, finançant sa restauration par une activité de mariages, d’événements et de tournages.',
    en: 'Daphne Reckert inherits the five-century-old château from her grandfather. With Ian Figueira, she sets out to revive the estate, funding its restoration through a business of weddings, events, and film shoots.',
  },
  {
    year: '2025',
    fr: 'La restauration est filmée pour HGTV : l’émission « Castle Impossible » suit Daphne et Ian, « the Figs », pièce après pièce. La première saison est diffusée d’avril à juin.',
    en: 'The restoration is filmed for HGTV: the series “Castle Impossible” follows Daphne and Ian, “the Figs”, room by room. The first season airs from April to June.',
  },
  {
    year: isFr ? 'Aujourd’hui' : 'Today',
    fr: `Le domaine de ${site.estate.hectares} hectares poursuit sa renaissance et accueille mariages, événements et tournages à travers ${site.estate.decors}+ décors distincts, à ${site.address.fromParisKm} km de Paris.`,
    en: `The ${site.estate.hectares}-hectare estate continues its renaissance, hosting weddings, events, and film shoots across ${site.estate.decors}+ distinct décors, ${site.address.fromParisKm} km from Paris.`,
  },
];

// The timeline runs as normal "beats"; its final point ("Today") is held back and
// rendered as a minimal terminus that pops out into the present-day HGTV section.
const beats = timelineEntries.slice(0, -1);
const todayEntry = timelineEntries[timelineEntries.length - 1];
---

<PageLayout
  title={isFr
    ? `Histoire du Château de Lésigny — Depuis ${site.founded}`
    : `History of Château de Lésigny — Since ${site.founded}`}
  description={isFr
    ? `Plus de ${yearsOld} ans d’histoire : de la Renaissance à la Galigaï, des Luynes aux Bourbon-Penthièvre, jusqu’à la restauration filmée pour « Castle Impossible » (HGTV).`
    : `Over ${yearsOld} years of history: from the Renaissance to la Galigaï, the Luynes to the Bourbon-Penthièvre, up to the restoration filmed for HGTV’s “Castle Impossible”.`}
  locale={locale}
  path="histoire/"
  ogImageKey="exterior-facade"
>

  <!-- ═══════════════════════════════════════════════
       1. EDITORIAL HERO — typographic "1508" over a
          real photograph behind a dark scrim.
       ═══════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero__bg">
      <Image
        src={carteHero}
        class="hero__bgimg"
        widths={[768, 1280, 1920, 2200]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        alt={isFr
          ? 'Carte ancienne du Gouvernement de l’Isle de France (1746), Lésigny aux portes de Paris'
          : 'Antique map of the Gouvernement de l’Isle de France (1746), Lésigny at the gates of Paris'}
      />
    </div>
    <div class="hero__scrim" aria-hidden="true"></div>

    <div class="wrap hero__inner">
      <div class="hero__title">
        <p class="eyebrow hero__eyebrow" data-reveal>
          {`${site.name} · Lésigny, Île-de-France`}
        </p>

        <div class="hero__numeral" aria-hidden="true" data-reveal>1508</div>

        <h1 id="hero-heading" class="hero__h1" data-reveal>
          {isFr ? 'Histoire & Patrimoine' : 'History & Heritage'}
        </h1>

        <p class="hero__deck" data-reveal>
          {isFr
            ? `Cinq siècles séparent la pose de la première pierre de notre présent. Un château Renaissance, des reines et des favoris de cour, une Révolution, puis une renaissance — l’histoire continue de s’écrire à ${site.address.fromParisKm} km de Paris.`
            : `Five centuries separate the laying of the first stone from our present. A Renaissance château, queens and royal favourites, a Revolution, then a renaissance — a history still being written ${site.address.fromParisKm} km from Paris.`}
        </p>
      </div>

      <figure class="hero__collage" data-reveal>
        <div class="hero__collage-stack">
          <div class="pcard pcard--marie">
            <Image src={portraitMarie} widths={[180, 360]} sizes="(max-width: 860px) 26vw, 9rem"
              alt={isFr ? 'Portrait de Marie de Médicis, reine de France' : 'Portrait of Marie de’ Medici, Queen of France'} />
          </div>
          <div class="pcard pcard--louis">
            <Image src={portraitLouis} widths={[180, 360]} sizes="(max-width: 860px) 26vw, 9rem"
              alt={isFr ? 'Portrait du roi Louis XIII' : 'Portrait of King Louis XIII'} />
          </div>
          <div class="pcard pcard--catherine">
            <Image src={portraitCatherine} widths={[160, 320]} sizes="(max-width: 860px) 22vw, 8rem"
              alt={isFr ? 'Portrait de Catherine de Médicis' : 'Portrait of Catherine de’ Medici'} />
          </div>
          <div class="pcard pcard--concini">
            <Image src={portraitConcini} widths={[160, 320]} sizes="(max-width: 860px) 22vw, 8rem"
              alt={isFr ? 'Portrait de Concino Concini, maréchal d’Ancre' : 'Portrait of Concino Concini, Maréchal d’Ancre'} />
          </div>
          <div class="pcard pcard--galigai">
            <Image src={portraitGaligai} widths={[260, 457]} sizes="(max-width: 860px) 34vw, 12rem"
              alt={isFr
                ? 'Portrait de Léonora Galigaï, maîtresse du château et figure de son âge d’or, peint vers 1614'
                : 'Portrait of Léonora Galigaï, mistress of the château and figure of its golden age, painted around 1614'} />
          </div>
        </div>
        <figcaption class="hero__portrait-cap slate">
          {isFr
            ? 'Figures de Lésigny — Galigaï, Concini, Louis XIII, Marie & Catherine de Médicis · XVIᵉ–XVIIᵉ s. · domaine public'
            : 'Figures of Lésigny — Galigaï, Concini, Louis XIII, Marie & Catherine de’ Medici · 16th–17th c. · public domain'}
        </figcaption>
      </figure>
    </div>

    <div class="wrap"><hr class="rule hero__rule" /></div>
  </section>


  <!-- ═══════════════════════════════════════════════
       2. TIMELINE — alternating left / right
       ═══════════════════════════════════════════════ -->
  <section class="section timeline-section" aria-labelledby="timeline-heading">
    <div class="wrap">
      <p class="eyebrow" data-reveal>{isFr ? 'Chronologie' : 'Timeline'}</p>
      <h2 id="timeline-heading" class="section-h2" data-reveal>
        {isFr ? `${yearsOld} ans en quelques jalons` : `${yearsOld} years in a few milestones`}
      </h2>

      <div class="timeline-grid">
        <ol class="timeline" role="list">
          {beats.map((entry, i) => (
            <li class:list={['timeline__entry', { 'timeline__entry--portrait': entry.portrait }]} id={`tl-entry-${i}`} data-tl-index={i} data-reveal>
              {entry.portrait && (
                <figure class="timeline__portrait">
                  <Image src={entry.portrait} alt={entry.cap} widths={[96, 192]} sizes="96px" />
                  <figcaption>{entry.cap}</figcaption>
                </figure>
              )}
              <p class="timeline__year" aria-label={isFr ? `Année ${entry.year}` : `Year ${entry.year}`}>
                {entry.year}
              </p>
              <p class="timeline__prose">{isFr ? entry.fr : entry.en}</p>
            </li>
          ))}
        </ol>

        <aside class="timeline-rail" aria-hidden="true">
          <ol class="rail">
            {beats.map((entry, i) => (
              <li class="rail__item" data-tl-rail={i}>
                <span class="rail__node"></span>
                <span class="rail__year">{entry.year}</span>
              </li>
            ))}
          </ol>
        </aside>
      </div>
    </div>

    <!-- Today terminus: the timeline's final point — minimal until reached, then
         it pops out into the present-day Castle Impossible / HGTV section. -->
    <div class="today">
      <div class="wrap today__marker" data-reveal>
        <span class="today__node" aria-hidden="true"></span>
        <p class="today__year">{todayEntry.year}</p>
        <p class="today__lead">{isFr ? todayEntry.fr : todayEntry.en}</p>
        <span class="today__cue slate" aria-hidden="true">{isFr ? 'La suite, aujourd’hui' : 'The story, today'}</span>
      </div>

      <section class="today__panel is-dark" aria-labelledby="feature-heading" data-reveal>
        <div class="wrap feature-wrap">
          <div class="feature__text">
            <p class="eyebrow feature__eyebrow">
              {isFr ? 'Castle Impossible · HGTV' : 'Castle Impossible · HGTV'}
            </p>
            <h2 id="feature-heading" class="feature__title">
              {isFr
                ? 'La renaissance d’un château, saison après saison'
                : 'A château’s renaissance, season after season'}
            </h2>
            <p class="feature__body">
              {isFr
                ? `La restauration contemporaine du château est filmée pour HGTV dans « Castle Impossible ». Daphne Reckert et Ian Figueira — « the Figs » — y redonnent vie, pièce après pièce, au domaine que Daphne a hérité de son grand-père. La première saison a été diffusée d’avril à juin 2025.`
                : `The château’s contemporary restoration is filmed for HGTV in “Castle Impossible”. Daphne Reckert and Ian Figueira — “the Figs” — revive, room by room, the estate Daphne inherited from her grandfather. The first season aired from April to June 2025.`}
            </p>
            <p class="feature__body">
              {isFr
                ? `La deuxième saison a été lancée le mardi 26 mai 2026 : huit épisodes, en streaming dès le lendemain sur HBO Max et discovery+. Au programme — une suite nuptiale dans la tour du colombier, un salon de thé, une taverne dans les souterrains, une bibliothèque, et la restauration de la maison de gardien.`
                : `Season two premiered on Tuesday 26 May 2026: eight episodes, streaming the next day on HBO Max and discovery+. On the agenda — a honeymoon suite in the dovecote tower, a tea salon, a dungeon tavern, a library, and the restoration of the gatehouse.`}
            </p>

            <div class="feature__actions">
              <a
                class="btn btn--primary"
                href={site.social.youtube}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={isFr ? 'Voir TheBeauChateau sur YouTube (nouvelle fenêtre)' : 'Watch TheBeauChateau on YouTube (opens in new tab)'}
              >
                {isFr ? 'Voir sur YouTube' : 'Watch on YouTube'}
              </a>
              <a
                class="btn btn--ghost feature__cta"
                href="https://www.hgtv.com/shows/castle-impossible"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={isFr ? 'Castle Impossible sur HGTV.com (nouvelle fenêtre)' : 'Castle Impossible on HGTV.com (opens in new tab)'}
              >
                {isFr ? 'La série sur HGTV' : 'The series on HGTV'}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false">
                  <path d="M2 2h10M12 2v10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </a>
            </div>
          </div>

          <figure class="feature__media">
            <Photo
              name="exterior-evening"
              ratio="4/5"
              alt={isFr
                ? 'Le Château de Lésigny illuminé à la tombée du jour'
                : 'Château de Lésigny lit at dusk'}
            />
            <figcaption class="feature__media-cap slate">
              {isFr ? 'Le château, au crépuscule' : 'The château at dusk'}
            </figcaption>
          </figure>
        </div>
      </section>
    </div>
  </section>



  <!-- ═══════════════════════════════════════════════
       4. ARCHITECTURE ESSAY — narrow column
       ═══════════════════════════════════════════════ -->
  <section class="section essay-section" aria-labelledby="essay-heading">
    <div class="wrap essay-wrap">
      <div class="essay__meta" data-reveal>
        <hr class="rule" />
        <p class="eyebrow essay__eyebrow">
          {isFr ? 'Architecture & Matériaux' : 'Architecture & Materials'}
        </p>
      </div>

      <h2 id="essay-heading" class="essay__title" data-reveal>
        {isFr
          ? 'Le premier Renaissance français — pierre de taille, douves et colombier'
          : 'The first French Renaissance — ashlar, moat, and dovecote'}
      </h2>

      <figure class="essay__plate" data-reveal>
        <Photo
          name="int-ballroom-red"
          ratio="16/9"
          alt={isFr
            ? 'Plafond à poutres et caissons peints de la grande salle de réception rouge du château'
            : 'Painted beamed and coffered ceiling of the château’s red reception hall'}
        />
        <figcaption class="essay__caption slate">
          {isFr
            ? 'Plafonds peints et cheminées des salles de réception · Renaissance'
            : 'Painted ceilings and fireplaces of the reception halls · Renaissance'}
        </figcaption>
      </figure>

      <div class="essay__text flow" data-reveal>
        {isFr ? (
          <>
            <p>
              L’architecture de Lésigny appartient au premier Renaissance français. Le château que
              vous parcourez aujourd’hui doit l’essentiel de sa silhouette à la reconstruction
              conduite vers le milieu du XVIᵉ siècle par Charles de Pierrevive et Charlotte
              Briçonnet, sur les fondations de la demeure des Poncher. On y reconnaît le vocabulaire
              de l’époque : pierre de taille, fenêtres à meneaux, lucarnes à frontons et toitures
              d’ardoise — un langage importé d’Italie, mais retenu avec la mesure francilienne.
            </p>
            <p>
              Le corps principal est ceint de douves en eau, alimentées par les pièces d’eau du
              parc — dispositif autant défensif qu’ornemental, hérité du château médiéval qui l’a
              précédé. À la Révolution, en 1794, les quatre tours d’angle furent abattues sur ordre
              du district et les étangs asséchés : le profil horizontal que vous voyez aujourd’hui
              garde la mémoire de cette amputation.
            </p>

            <figure class="essay__plan" data-reveal>
              <Photo
                name="plan-floorplan"
                ratio="3/2"
                duotone
                alt={isFr
                  ? 'Plan ancien du château et de ses tours d’angle disparues'
                  : 'Historic plan of the château and its lost corner towers'}
              />
              <figcaption class="essay__caption slate">
                {isFr
                  ? 'Le plan du château, avant la perte des tours'
                  : 'Plan of the château, before the loss of its towers'}
              </figcaption>
            </figure>

            <p>
              Au sein du domaine, le colombier rappelle les privilèges seigneuriaux de l’Ancien
              Régime, quand le droit de pigeonnier signalait le rang du propriétaire. La chapelle,
              consacrée en 1615 du temps de la Galigaï, vit en 1617 le mariage de Charles de Luynes
              et de Marie de Rohan — l’un des épisodes les plus romanesques de l’histoire du lieu.
            </p>

            <div class="essay__duo" data-reveal>
              <figure>
                <Photo
                  name="grounds-moat"
                  ratio="4/5"
                  duotone
                  alt="Douves en eau au pied du Château de Lésigny"
                />
                <figcaption class="essay__caption slate">{isFr ? 'Les douves' : 'The moat'}</figcaption>
              </figure>
              <figure>
                <Photo
                  name="grounds-dovecote"
                  ratio="4/5"
                  duotone
                  alt={isFr ? 'Colombier du domaine de Lésigny' : 'Dovecote of the Lésigny estate'}
                />
                <figcaption class="essay__caption slate">{isFr ? 'Le colombier' : 'The dovecote'}</figcaption>
              </figure>
            </div>

            <p>
              À l’intérieur, les salles de réception du rez-de-chaussée conservent plafonds peints
              et cheminées qui leur donnent un caractère exceptionnel. Ces décors, enrichis au fil
              des siècles par des propriétaires successifs, expliquent pourquoi tant de productions
              de cinéma et de télévision ont reconnu en Lésigny un cadre intemporel.
            </p>
            <p>
              Le domaine s’étend sur {site.estate.hectares} hectares — parc boisé, douves, terrasses
              et une cour d’un hectare — où chaque espace forme un décor autonome. C’est cette
              diversité qui fonde les {site.estate.decors}+ lieux aujourd’hui ouverts aux mariages,
              aux événements et aux tournages.
            </p>
          </>
        ) : (
          <>
            <p>
              The architecture of Lésigny belongs to the first French Renaissance. The château you
              walk through today owes its silhouette largely to the rebuild carried out around the
              middle of the 16th century by Charles de Pierrevive and Charlotte Briçonnet, on the
              foundations of the Poncher house. The vocabulary of the era is unmistakable: ashlar,
              mullioned windows, pedimented dormers, and slate roofs — a language imported from
              Italy yet held to an Île-de-France restraint.
            </p>
            <p>
              The main body is encircled by a water-filled moat, fed by the park’s ponds — a device
              as defensive as it is ornamental, inherited from the medieval castle that preceded it.
              In 1794, the Revolution had the four corner towers pulled down by order of the
              district and the ponds drained: the horizontal profile you see today still carries the
              memory of that loss.
            </p>

            <figure class="essay__plan" data-reveal>
              <Photo
                name="plan-floorplan"
                ratio="3/2"
                duotone
                alt="Historic plan of the château and its lost corner towers"
              />
              <figcaption class="essay__caption slate">
                Plan of the château, before the loss of its towers
              </figcaption>
            </figure>

            <p>
              Within the estate, the dovecote recalls the seigneurial privileges of the Ancien
              Régime, when the right to keep pigeons signalled the owner’s rank. The chapel,
              consecrated in 1615 in la Galigaï’s day, witnessed in 1617 the marriage of Charles de
              Luynes and Marie de Rohan — one of the most novelistic episodes in the château’s
              history.
            </p>

            <div class="essay__duo" data-reveal>
              <figure>
                <Photo
                  name="grounds-moat"
                  ratio="4/5"
                  duotone
                  alt="Water-filled moat at the foot of Château de Lésigny"
                />
                <figcaption class="essay__caption slate">The moat</figcaption>
              </figure>
              <figure>
                <Photo
                  name="grounds-dovecote"
                  ratio="4/5"
                  duotone
                  alt="Dovecote of the Lésigny estate"
                />
                <figcaption class="essay__caption slate">The dovecote</figcaption>
              </figure>
            </div>

            <p>
              Inside, the ground-floor reception halls retain painted ceilings and fireplaces that
              give them exceptional character. These décors, enriched over the centuries by
              successive owners, explain why so many film and television productions have recognised
              in Lésigny a timeless frame.
            </p>
            <p>
              The estate spreads across {site.estate.hectares} hectares — wooded park, moats,
              terraces, and a one-hectare courtyard — where each space forms a self-contained set.
              That diversity underpins the {site.estate.decors}+ locations now open to weddings,
              events, and film shoots.
