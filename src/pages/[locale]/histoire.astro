<script>
  // Highlight the condensed rail’s active year as its narrative entry scrolls
  // into view. Purely a visual aid — degrades gracefully without JS/observer.
  const entries = Array.from(document.querySelectorAll<HTMLElement>('.timeline__entry'));
  const railItems = Array.from(document.querySelectorAll<HTMLElement>('.rail__item'));

  if (entries.length && railItems.length && 'IntersectionObserver' in window) {
    const visible = new Map<number, number>();

    const setActive = (idx: number) => {
      railItems.forEach((el, i) => el.classList.toggle('is-active', i === idx));
    };

    const observer = new IntersectionObserver(
      (records) => {
        for (const record of records) {
          const idx = Number(record.target.getAttribute('data-tl-index'));
          if (record.isIntersecting) visible.set(idx, record.intersectionRatio);
          else visible.delete(idx);
        }
        if (visible.size) setActive(Math.min(...visible.keys()));
      },
      { rootMargin: '-20% 0px -60% 0px', threshold: [0, 0.25, 0.6, 1] },
    );

    entries.forEach((el) => observer.observe(el));
  }
</script>


